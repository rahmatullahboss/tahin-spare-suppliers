{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tahin-spare-suppliers",
  "compatibility_date": "2026-03-29",
  "r2_buckets": [
    {
      "binding": "MEDIA_BUCKET",
      "bucket_name": "tahin-spare-suppliers-media"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "e8d999cbc9f74919ab062abb24b976c9"
    }
  ],
  "vars": {
    "DATABASE_URL": "",
    "ADMIN_PASSWORD": "",
    "SESSION_SECRET": "",
    "MEDIA_PUBLIC_URL": ""
  }
}
