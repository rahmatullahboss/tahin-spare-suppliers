---
import MainLayout from '../layouts/MainLayout.astro';
import Icon from '../components/Icon.astro';
---
<MainLayout title="Our Strength - Tahin Spare Suppliers" activeNav="about">
  <section class="page-hero">
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <h1 class="reveal">Our Strength</h1>
      <p class="reveal">Home / About Us / Our Strength</p>
    </div>
  </section>

  <section class="section" style="background:#f9f9f9;">
    <div class="container">
      <h2 class="section-title">WHY PARTNER WITH US</h2>
      <p class="section-subtitle" style="color:#555;">What makes Tahin Spare Suppliers your reliable partner</p>
      <div class="strength-grid reveal-stagger">
        <div class="strength-card">
          <Icon name="map-marker-alt" size={40} class="strength-icon" />
          <h3>Direct Sourcing</h3>
          <p>Being located at the source (Chattogram Ship-Breaking Hub), we offer the most competitive prices in the international market.</p>
        </div>
        <div class="strength-card">
          <Icon name="warehouse" size={40} class="strength-icon" />
          <h3>Ready-to-Ship Stock</h3>
          <p>We maintain a large inventory at our Bhatiari warehouse, allowing for quick response times and physical or video inspections before purchase.</p>
        </div>
        <div class="strength-card">
          <Icon name="globe" size={40} class="strength-icon" />
          <h3>Global Reach</h3>
          <p>Experienced in facilitating worldwide shipping via air or sea freight, ensuring your spares reach your vessel's next port of call.</p>
        </div>
        <div class="strength-card">
          <Icon name="check-circle" size={40} class="strength-icon" />
          <h3>Transparency & Trust</h3>
          <p>We provide detailed photos, load test videos, and technical reports to ensure full client satisfaction before shipping.</p>
        </div>
      </div>
      
      <div class="strength-details">
        <div class="text-content reveal-left">
          <h3>Unmatched Industry Experience</h3>
          <p>With decades of operational excellence in the marine spare parts sector, we possess deep technical knowledge and a broad network within the Chattogram Ship-Breaking Hub. This expertise allows us to identify and procure the highest quality components from decommissioned vessels, ensuring that our clients receive parts that meet stringent maritime standards.</p>
          <p>Our commitment extends beyond simply supplying parts; we act as a strategic partner to ship owners, managers, and repair yards worldwide, providing reliable solutions that minimize downtime and optimize vessel performance.</p>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-hero {
    position: relative;
    height: 350px;
    background: url('/images/hero-bg.webp') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .page-hero-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); }
  .page-hero-content { position: relative; z-index: 1; color: #fff; }
  .page-hero-content h1 { font-size: 36px; font-weight: 700; margin-bottom: 8px; }
  .page-hero-content p { font-size: 14px; color: #ddd; }

  /* Strength */
  .strength-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
    margin-bottom: 50px;
  }
  .strength-card {
    text-align: center;
    padding: 35px 20px;
    background: #fff;
    border-radius: 10px;
    box-shadow: 0 2px 15px rgba(0,0,0,0.08);
    transition: transform 0.3s;
  }
  .strength-card:hover { transform: translateY(-5px); }
  .strength-card :global(.strength-icon) {
    color: #c0392b;
    margin-bottom: 15px;
  }
  .strength-card h3 {
    font-size: 17px;
    font-weight: 700;
    margin-bottom: 10px;
    color: #222;
  }
  .strength-card p {
    font-size: 13px;
    color: #666;
    line-height: 1.6;
  }

  .strength-details {
    max-width: 800px;
    margin: 0 auto;
    background: #fff;
    padding: 40px;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
  }
  .strength-details h3 {
    font-size: 22px;
    color: #c0392b;
    margin-bottom: 15px;
  }
  .strength-details p {
    font-size: 15px;
    color: #555;
    line-height: 1.8;
    margin-bottom: 15px;
  }

  @media (max-width: 768px) {
    .strength-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .strength-grid { grid-template-columns: 1fr; }
    .strength-details { padding: 20px; }
  }
</style>
