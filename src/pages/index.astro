---
import MainLayout from '../layouts/MainLayout.astro';
import Icon from '../components/Icon.astro';

const shipmentImages = [
  '/images/shipments/shipment-01.webp',
  '/images/shipments/shipment-02.webp',
  '/images/shipments/shipment-03.webp',
  '/images/shipments/shipment-04.webp',
  '/images/shipments/shipment-05.webp',
  '/images/shipments/shipment-06.webp',
  '/images/shipments/shipment-07.webp',
  '/images/shipments/shipment-08.webp'
];
---
<MainLayout activeNav="home" preloadImage="/images/hero-bg-new.webp">
  <!-- Hero Section -->
  <section class="hero">
    <img src="/images/hero-bg-new.webp" alt="" class="hero-bg" fetchpriority="high" loading="eager" decoding="sync" width="1376" height="768" />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h2 class="hero-title">WORLD-CLASS<br/>MARINE<br/>SOLUTIONS</h2>
      <p class="hero-subtitle">Your one-stop solution for reconditioned marine engines & equipment</p>
      <a href="/enquiry" class="btn btn-quote">Request a Quote</a>
    </div>
  </section>

  <!-- Who We Are -->
  <section class="section who-we-are">
    <div class="container">
      <h2 class="section-title reveal">WHO WE ARE</h2>
      <p class="section-subtitle reveal">Leading Marine Machinery & Spare Parts Supplier from Bangladesh</p>
      <p class="who-desc reveal">
        Tahin Spare Suppliers has been serving the marine industry since 1990, specializing in the supply of reconditioned marine engines, spare parts, generators, hydraulic components, and a wide range of marine equipment worldwide. Strategically located near the Chattogram Ship-Recycling Yards in Bangladesh, we have direct access to a vast and reliable inventory, enabling us to provide quality products with consistent availability at competitive prices to our global clients.
      </p>
    </div>
  </section>

  <!-- Our Equipments -->
  <section class="section stock-spares">
    <div class="container">
      <h2 class="stock-title reveal">Our Equipments</h2>
      <p class="stock-subtitle reveal">Your one-stop solution for reconditioned marine engines & equipment</p>
      <div class="stock-grid reveal-stagger">
        <a href="/products" class="stock-card">
          <div class="stock-card-img">
            <img src="/images/marine-propulsion-engine.jpg" alt="Marine Propulsion Engine" loading="lazy" />
          </div>
          <div class="stock-card-content">
            <h3>Marine Propulsion Engine</h3>
            <span class="stock-card-cta">VIEW DETAILS</span>
          </div>
        </a>
        <a href="/products" class="stock-card">
          <div class="stock-card-img">
            <img src="/images/marine-gearbox.jpg" alt="Marine Gearbox" loading="lazy" />
          </div>
          <div class="stock-card-content">
            <h3>Marine Gearbox</h3>
            <span class="stock-card-cta">VIEW DETAILS</span>
          </div>
        </a>
        <a href="/products" class="stock-card">
          <div class="stock-card-img">
            <img src="/images/auxiliary-engine.jpg" alt="Auxiliary Engine" loading="lazy" />
          </div>
          <div class="stock-card-content">
            <h3>Auxiliary Engine</h3>
            <span class="stock-card-cta">VIEW DETAILS</span>
          </div>
        </a>
        <a href="/products" class="stock-card">
          <div class="stock-card-img">
            <img src="/images/diesel-generator-set.jpg" alt="Diesel & Gas Generator Set" loading="lazy" />
          </div>
          <div class="stock-card-content">
            <h3>Diesel & Gas Generator Set</h3>
            <span class="stock-card-cta">VIEW DETAILS</span>
          </div>
        </a>
        <a href="/products" class="stock-card">
          <div class="stock-card-img">
            <img src="/images/spare-parts-new.jpg" alt="Spare Parts" loading="lazy" />
          </div>
          <div class="stock-card-content">
            <h3>Spare Parts</h3>
            <span class="stock-card-cta">VIEW DETAILS</span>
          </div>
        </a>
        <a href="/products" class="stock-card">
          <div class="stock-card-img">
            <img src="/images/hydraulic-crane-equipment.jpg" alt="Hydraulic Deck Crane Equipment" loading="lazy" />
          </div>
          <div class="stock-card-content">
            <h3>Hydraulic Deck Crane Equipment</h3>
            <span class="stock-card-cta">VIEW DETAILS</span>
          </div>
        </a>
        <a href="/products" class="stock-card">
          <div class="stock-card-img">
            <img src="/images/anchor-chain.jpg" alt="Anchor and Chain" loading="lazy" />
          </div>
          <div class="stock-card-content">
            <h3>Anchor and Chain</h3>
            <span class="stock-card-cta">VIEW DETAILS</span>
          </div>
        </a>
      </div>


    </div>
  </section>

  <!-- Major Brands Marquee -->
  <section class="brands-section">
    <div class="container">
      <h2 class="brands-title reveal">MAJOR BRANDS WE CARRY</h2>
    </div>
    <div class="brands-marquee">
      <div class="brands-track">
        <img src="/images/brands/yanmar-1.svg" alt="Yanmar" class="brand-logo" />
        <img src="/images/brands/caterpillar-logo2.svg" alt="Caterpillar" class="brand-logo" />
        <img src="/images/brands/man-logo.svg" alt="MAN" class="brand-logo" />
        <img src="/images/brands/wartsila.svg" alt="Wartsila" class="brand-logo" />
        <img src="/images/brands/rolls-royce.svg" alt="Rolls-Royce" class="brand-logo" />
        <img src="/images/brands/mtu-friedrichshafen-logo.svg" alt="MTU" class="brand-logo" />
        <img src="/images/brands/cummins.svg" alt="Cummins" class="brand-logo" />
        <img src="/images/brands/mitsubishi-1.svg" alt="Mitsubishi" class="brand-logo" />
        <img src="/images/brands/daihatsu-3.svg" alt="Daihatsu" class="brand-logo" />
        <img src="/images/brands/detroit-diesel-logo.svg" alt="Detroit Diesel" class="brand-logo" />
        
        <!-- Duplicate for seamless loop -->
        <img src="/images/brands/yanmar-1.svg" alt="Yanmar" class="brand-logo" />
        <img src="/images/brands/caterpillar-logo2.svg" alt="Caterpillar" class="brand-logo" />
        <img src="/images/brands/man-logo.svg" alt="MAN" class="brand-logo" />
        <img src="/images/brands/wartsila.svg" alt="Wartsila" class="brand-logo" />
        <img src="/images/brands/rolls-royce.svg" alt="Rolls-Royce" class="brand-logo" />
        <img src="/images/brands/mtu-friedrichshafen-logo.svg" alt="MTU" class="brand-logo" />
        <img src="/images/brands/cummins.svg" alt="Cummins" class="brand-logo" />
        <img src="/images/brands/mitsubishi-1.svg" alt="Mitsubishi" class="brand-logo" />
        <img src="/images/brands/daihatsu-3.svg" alt="Daihatsu" class="brand-logo" />
        <img src="/images/brands/detroit-diesel-logo.svg" alt="Detroit Diesel" class="brand-logo" />
      </div>
    </div>
  </section>

  <!-- Our Services -->
  <section class="section services-section">
    <div class="container">
      <h2 class="section-title reveal" style="color:#222;">OUR SERVICES</h2>
      <p class="section-subtitle reveal">Supplying quality marine engine parts & equipment worldwide</p>
      <div class="services-grid reveal-stagger">
        <a href="/services" class="service-card">
          <div class="service-icon"><Icon name="layer-group" size={40} /></div>
          <h3>Marine Engine Parts Supply</h3>
          <p>Supply and export of all kinds of reconditioned marine engine spare parts — pistons, liners, bearings, valves, gaskets, turbochargers, fuel pumps and more.</p>
        </a>
        <a href="/services" class="service-card">
          <div class="service-icon"><Icon name="tools" size={40} /></div>
          <h3>Engine Overhaul & Reconditioning</h3>
          <p>Complete engine disassembly, inspection, cleaning, reconditioning and testing for Yanmar, Daihatsu, Caterpillar and all major marine engine brands.</p>
        </a>
        <a href="/services" class="service-card">
          <div class="service-icon"><Icon name="globe" size={40} /></div>
          <h3>Worldwide Parts Export</h3>
          <p>Reliable worldwide export of marine engines, generator sets, hydraulic equipment and all engine spare parts from our Chattogram ship-breaking yard hub.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Global Export & Logistics -->
  <section class="export-logistics">
    <div class="container">
      <div class="export-shell">
        <div class="export-header reveal">
          <span class="export-kicker">Worldwide Marine Supply Chain</span>
          <h2 class="export-title">GLOBAL EXPORT &amp; LOGISTICS</h2>
          <p class="export-subtitle">
            Proudly serving the global marine industry with secure crating, verified stock handling and complete export documentation for fast overseas delivery.
          </p>
        </div>
        <div class="export-grid reveal-stagger">
          <article class="export-card">
            <img src="/images/export-crating.webp" alt="Professional crating of marine engine" loading="lazy" width="900" height="900" />
            <div class="export-card-content">
              <h3>Professional Crating &amp;<br/>Secure Packaging.</h3>
            </div>
          </article>
          <article class="export-card">
            <img src="/images/export-stock.webp" alt="Verified marine stock available" loading="lazy" width="900" height="900" />
            <div class="export-card-content">
              <h3>Verified Stock &amp;<br/>Immediate Availability.</h3>
            </div>
          </article>
          <article class="export-card">
            <img src="/images/export-spare-parts.webp" alt="Wood-crated secure spare parts supply" loading="lazy" width="900" height="900" />
            <div class="export-card-content">
              <h3>Secure Wood-Crated<br/>Spare Parts Supply.</h3>
            </div>
          </article>
          <article class="export-card">
            <img src="/images/export-docs.webp" alt="Complete export documentation" loading="lazy" width="900" height="900" />
            <div class="export-card-content">
              <h3>Complete Export<br/>Documentation &amp; Fast<br/>Clearance.</h3>
            </div>
          </article>
        </div>
        <div class="export-cta reveal">
          <a href="/enquiry" class="btn btn-quote">Request a Quote</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Recent Shipment -->
  <section class="recent-shipments">
    <div class="container">
      <h2 class="recent-shipments-title reveal">SOME OF OUR SHIPMENTS</h2>
    </div>
    <div class="recent-shipments-marquee">
      <div class="recent-shipments-track">
        {shipmentImages.map((image, index) => (
          <img src={image} alt={`Recent marine shipment ${index + 1}`} class="shipment-marquee-image" loading="lazy" width="960" height="1280" />
        ))}
        {shipmentImages.map((image, index) => (
          <img src={image} alt="" class="shipment-marquee-image" loading="lazy" width="960" height="1280" aria-hidden="true" />
        ))}
      </div>
    </div>
  </section>

  <!-- Equipments & Services CTA -->
  <section class="product-services">
    <div class="ps-overlay"></div>
    <div class="container ps-content">
      <h2 class="ps-title reveal-scale">Looking for Marine Equipment?</h2>
      <p class="ps-contact reveal">Call us: +880 1787-429268 / +88-01710917904 or Email: tahinship@gmail.com</p>
      <div class="ps-carousel reveal">
        <div class="ps-carousel-track">
          <div class="ps-card">
            <img src="/images/marine-engine.webp" alt="Marine Engine" loading="lazy" />
          </div>
          <div class="ps-card">
            <img src="/images/diesel-generator.webp" alt="Diesel Generator" loading="lazy" />
          </div>
          <div class="ps-card">
            <img src="/images/turbocharger.webp" alt="Turbocharger" loading="lazy" />
          </div>
          <div class="ps-card">
            <img src="/images/hydraulic-crane.webp" alt="Hydraulic Crane" loading="lazy" />
          </div>
          <div class="ps-card">
            <img src="/images/spare-parts.webp" alt="Spare Parts" loading="lazy" />
          </div>
        </div>
        <button class="ps-nav ps-prev" aria-label="Previous"><Icon name="chevron-left" size={16} /></button>
        <button class="ps-nav ps-next" aria-label="Next"><Icon name="chevron-right" size={16} /></button>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section why-choose-us">
    <div class="container">
      <h2 class="section-title reveal" style="text-transform: capitalize;">Why Choose Us</h2>
      <div class="features-grid">
        <div class="feature-card reveal-scale">
          <div class="feature-icon"><Icon name="globe" size={40} /></div>
          <h3>GLOBAL REACH</h3>
          <p>Sourcing Worldwide,<br/>Fast Delivery.</p>
        </div>
        <div class="feature-card reveal-scale">
          <div class="feature-icon"><Icon name="award" size={40} /></div>
          <h3>UNMATCHED QUALITY</h3>
          <p>Tested Components,<br/>Guaranteed Performance.</p>
        </div>
        <div class="feature-card reveal-scale">
          <div class="feature-icon"><Icon name="headset" size={40} /></div>
          <h3>EXPERT SUPPORT</h3>
          <p>Dedicated Technical<br/>Support Team.</p>
        </div>
        <div class="feature-card reveal-scale">
          <div class="feature-icon"><Icon name="ship" size={40} /></div>
          <h3>URGENT LOGISTICS</h3>
          <p>Prioritized Shipping for<br/>Vetting & Spares.</p>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    min-height: 700px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    will-change: transform;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      rgba(30, 40, 60, 0.4) 0%,
      rgba(25, 35, 55, 0.25) 40%,
      rgba(15, 25, 45, 0.1) 100%
    );
    z-index: 1;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 60px;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    animation: heroFadeIn 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(35px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  .hero-title {
    color: #fff;
    font-size: 52px;
    font-weight: 800;
    line-height: 1.12;
    margin-bottom: 24px;
    font-family: var(--font-inter), 'Inter', sans-serif;
    text-shadow: 0 4px 30px rgba(0,0,0,0.35);
    text-transform: uppercase;
    letter-spacing: -0.5px;
    max-width: 700px;
  }
  .hero-subtitle {
    font-size: 16px;
    font-weight: 400;
    color: rgba(255,255,255,0.88);
    line-height: 1.7;
    margin-bottom: 32px;
    max-width: 500px;
    font-style: italic;
  }

  /* Request a Quote Button — Copper/Brown */
  .btn-quote {
    display: inline-block;
    padding: 14px 36px;
    background: linear-gradient(135deg, #a67c52, #8b6240);
    color: #fff;
    font-size: 15px;
    font-weight: 600;
    border-radius: 6px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(139, 98, 64, 0.4);
    width: fit-content;
  }
  .btn-quote:hover {
    background: linear-gradient(135deg, #b98a5c, #9a7050);
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(139, 98, 64, 0.55);
  }
  .btn-quote:active {
    transform: translateY(0);
  }



  /* Who We Are */
  .who-we-are {
    text-align: center;
    background: #fff;
  }
  .who-desc {
    max-width: 850px;
    margin: 0 auto;
    font-size: 15px;
    color: #555;
    line-height: 1.8;
  }

  /* Stock Spares / Products — Premium Overlay Cards */
  /* Brands Marquee */
  .brands-section {
    padding: 60px 0 50px;
    background: #fff;
    overflow: hidden;
    border-bottom: 1px solid #eee;
    border-top: 1px solid #eee;
  }
  .brands-title {
    text-align: center;
    font-size: 22px;
    font-weight: 700;
    color: #222;
    margin-bottom: 40px;
    letter-spacing: 2px;
  }
  .brands-marquee {
    overflow: hidden;
    position: relative;
    padding: 10px 0;
  }
  .brands-marquee::before,
  .brands-marquee::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 150px;
    z-index: 2;
  }
  .brands-marquee::before {
    left: 0;
    background: linear-gradient(to right, #fff, transparent);
  }
  .brands-marquee::after {
    right: 0;
    background: linear-gradient(to left, #fff, transparent);
  }
  .brands-track {
    display: flex;
    gap: 80px;
    animation: marquee-scroll 35s linear infinite;
    width: max-content;
    align-items: center;
  }
  .brand-logo {
    height: 45px;
    width: auto;
    max-width: 160px;
    object-fit: contain;
    opacity: 0.9;
    transition: all 0.4s ease;
  }
  .brand-logo:hover {
    opacity: 1;
    transform: scale(1.05);
  }
  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .stock-spares {
    background: #f9f9f9;
  }
  .stock-title {
    text-align: center;
    font-size: 28px;
    font-weight: 700;
    color: #222;
    margin-bottom: 8px;
  }
  .stock-subtitle {
    text-align: center;
    color: #c0392b;
    font-size: 15px;
    margin-bottom: 40px;
    font-weight: 500;
  }
  .stock-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .stock-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border: 1px solid #eaeaea;
    background: #fff;
    border-radius: 0;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
    box-shadow: 0 4px 15px rgba(0,0,0,0.04);
    transition: transform 0.4s cubic-bezier(0.33, 1, 0.68, 1), box-shadow 0.4s ease;
    will-change: transform;
  }
  .stock-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 35px rgba(0,0,0,0.1);
  }
  .stock-card-img {
    width: 100%;
    height: 220px;
    position: relative;
    overflow: hidden;
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 92%);
  }
  .stock-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.33, 1, 0.68, 1);
  }
  .stock-card:hover .stock-card-img img {
    transform: scale(1.08);
  }
  .stock-card-content {
    padding: 24px 24px 30px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    justify-content: center;
    background: #fff;
  }
  .stock-card h3 {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 20px;
    line-height: 1.3;
    color: #111;
    font-family: var(--font-inter), 'Inter', sans-serif;
  }
  .stock-card-cta {
    font-size: 13px;
    font-weight: 600;
    color: #e67e22;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: color 0.3s ease;
    display: block;
  }
  .stock-card:hover .stock-card-cta {
    color: #c0392b;
  }

  /* Services Section */
  .services-section {
    background: #fff;
  }
  .services-grid {
    display: flex;
    justify-content: center;
    gap: 30px;
  }
  .service-card {
    text-align: center;
    padding: 40px 25px;
    background: #f9f9f9;
    border-radius: 14px;
    transition: transform 0.4s cubic-bezier(0.33, 1, 0.68, 1),
                box-shadow 0.4s ease,
                background 0.3s;
    display: block;
    color: inherit;
    border: 1px solid transparent;
  }
  .service-card:hover {
    transform: translateY(-8px);
    background: #fff;
    border-color: rgba(192, 57, 43, 0.1);
  }
  .service-icon {
    color: #c0392b;
    margin-bottom: 20px;
  }
  .service-card h3 {
    font-size: 18px;
    font-weight: 700;
    color: #222;
    margin-bottom: 12px;
    transition: color 0.3s;
  }
  .service-card:hover h3 {
    color: #c0392b;
  }
  .service-card p {
    font-size: 14px;
    color: #666;
    line-height: 1.7;
  }

  /* Global Export & Logistics */
  .export-logistics {
    padding: 90px 0;
    background:
      linear-gradient(180deg, rgba(255, 248, 229, 0.94), rgba(247, 237, 208, 0.92)),
      linear-gradient(135deg, #f7eed6 0%, #efe1b4 100%);
    border-top: 1px solid rgba(166, 124, 82, 0.12);
    border-bottom: 1px solid rgba(166, 124, 82, 0.12);
  }
  .export-shell {
    max-width: 1040px;
    margin: 0 auto;
  }
  .export-header {
    max-width: 760px;
    margin: 0 auto 42px;
    text-align: center;
  }
  .export-kicker {
    display: inline-block;
    margin-bottom: 12px;
    color: #8b6240;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .export-title {
    margin-bottom: 14px;
    color: #1d1b17;
    font-size: 40px;
    line-height: 1.1;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    font-family: var(--font-playfair), 'Playfair Display', serif;
  }
  .export-subtitle {
    margin: 0;
    color: #4f4a41;
    font-size: 16px;
    line-height: 1.75;
  }
  .export-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }
  .export-card {
    overflow: hidden;
    border-radius: 22px;
    background: rgba(255,255,255,0.9);
    border: 1px solid rgba(166, 124, 82, 0.12);
    box-shadow: 0 14px 34px rgba(88, 66, 40, 0.14);
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }
  .export-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 40px rgba(88, 66, 40, 0.18);
  }
  .export-card img {
    width: 100%;
    height: 280px;
    object-fit: cover;
    display: block;
  }
  .export-card-content {
    padding: 20px 22px 24px;
    text-align: center;
  }
  .export-card-content h3 {
    margin-bottom: 10px;
    color: #1f1d19;
    font-size: 21px;
    line-height: 1.25;
    font-weight: 700;
