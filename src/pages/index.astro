---
import MainLayout from '../layouts/MainLayout.astro';
import Icon from '../components/Icon.astro';
---
<MainLayout activeNav="home" preloadImage="/images/hero-bg.webp">
  <!-- Hero Section -->
  <section class="hero">
    <img src="/images/hero-bg.webp" alt="" class="hero-bg" fetchpriority="high" loading="eager" decoding="sync" width="1200" height="750" />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h2 class="hero-title">WORLD-CLASS<br/>MARINE<br/>SOLUTIONS</h2>
      <p class="hero-subtitle">Extensive Inventory of High-Quality, Tested &<br/>Reliable Reconditioned Components.<br/>(Exporters & Suppliers).</p>
      <a href="/enquiry" class="btn btn-quote">Request a Quote</a>
    </div>
    <!-- Spare Parts Strip -->
    <div class="parts-strip">
      <div class="parts-strip-item">
        <img src="/images/spare-parts.webp" alt="Pistons" loading="eager" />
        <span class="parts-label">Pistons</span>
      </div>
      <div class="parts-strip-item">
        <img src="/images/turbocharger.webp" alt="Con-rods" loading="eager" />
        <span class="parts-label">Con-rods</span>
      </div>
      <div class="parts-strip-item">
        <img src="/images/heat-exchanger.webp" alt="Cylinder Head" loading="eager" />
        <span class="parts-label">Cylinder Head</span>
      </div>
      <div class="parts-strip-item">
        <img src="/images/pump-compressor.webp" alt="Fuel Injection Pump" loading="eager" />
        <span class="parts-label">Fuel Injection Pump</span>
      </div>
      <div class="parts-strip-item">
        <img src="/images/engine.webp" alt="Main Bearing Set" loading="eager" />
        <span class="parts-label">Main Bearing Set</span>
      </div>
      <div class="parts-strip-item">
        <img src="/images/marine-engine.webp" alt="Camshaft" loading="eager" />
        <span class="parts-label">Camshaft</span>
      </div>
    </div>
  </section>

  <!-- Who We Are -->
  <section class="section who-we-are">
    <div class="container">
      <h2 class="section-title reveal">WHO WE ARE</h2>
      <p class="section-subtitle reveal">Leading Marine Machinery & Spare Parts Supplier from Bangladesh</p>
      <p class="who-desc reveal">
        Tahin Spare Suppliers has been serving the marine industry since 1990, specializing in the supply of reconditioned marine engines, spare parts, generators, hydraulic components, and a wide range of marine equipment worldwide. Strategically located near the Chattogram Ship-Recycling Yards in Bangladesh, we have direct access to a vast and reliable inventory, enabling us to provide quality products with consistent availability at competitive prices to our global clients.
      </p>
    </div>
  </section>

  <!-- Our Equipments -->
  <section class="section stock-spares">
    <div class="container">
      <h2 class="stock-title reveal">Our Equipments</h2>
      <p class="stock-subtitle reveal">Your one-stop solution for reconditioned marine engines & equipment</p>
      <div class="stock-grid reveal-stagger">
        <a href="/products" class="stock-card">
          <div class="stock-card-img">
            <img src="/images/marine-engine.webp" alt="Marine Propulsion Engine" loading="lazy" />
          </div>
          <div class="stock-card-overlay">
            <span class="stock-card-tag">Engines</span>
            <h3>Marine Propulsion Engine</h3>
            <p>Main propulsion engines from Yanmar, Daihatsu, Caterpillar, MAN B&W</p>
            <span class="stock-card-cta">Explore →</span>
          </div>
        </a>
        <a href="/products" class="stock-card">
          <div class="stock-card-img">
            <img src="/images/marine-gearbox.jpg" alt="Marine Gearbox" loading="lazy" />
          </div>
          <div class="stock-card-overlay">
            <span class="stock-card-tag">Transmission</span>
            <h3>Marine Gearbox</h3>
            <p>High-quality reconditioned marine gearboxes for various engine models</p>
            <span class="stock-card-cta">Explore →</span>
          </div>
        </a>
        <a href="/products" class="stock-card">
          <div class="stock-card-img">
            <img src="/images/auxiliary-engine.jpg" alt="Auxiliary Engine" loading="lazy" />
          </div>
          <div class="stock-card-overlay">
            <span class="stock-card-tag">Auxiliary</span>
            <h3>Auxiliary Engine</h3>
            <p>Reliable auxiliary engines for onboard power and machinery</p>
            <span class="stock-card-cta">Explore →</span>
          </div>
        </a>
        <a href="/products" class="stock-card">
          <div class="stock-card-img">
            <img src="/images/diesel-generator-set.jpg" alt="Diesel & Gas Generator Set" loading="lazy" />
          </div>
          <div class="stock-card-overlay">
            <span class="stock-card-tag">Generators</span>
            <h3>Diesel & Gas Generator Set</h3>
            <p>Complete generator sets from 20 KVA to 2000 KVA</p>
            <span class="stock-card-cta">Explore →</span>
          </div>
        </a>
        <a href="/products" class="stock-card">
          <div class="stock-card-img">
            <img src="/images/spare-parts-new.jpg" alt="Spare Parts" loading="lazy" />
          </div>
          <div class="stock-card-overlay">
            <span class="stock-card-tag">Parts</span>
            <h3>Spare Parts</h3>
            <p>Pistons, liners, bearings, valves, turbochargers & more</p>
            <span class="stock-card-cta">Explore →</span>
          </div>
        </a>
        <a href="/products" class="stock-card">
          <div class="stock-card-img">
            <img src="/images/hydraulic-crane-equipment.jpg" alt="Hydraulic Deck Crane Equipment" loading="lazy" />
          </div>
          <div class="stock-card-overlay">
            <span class="stock-card-tag">Hydraulic</span>
            <h3>Hydraulic Deck Crane Equipment</h3>
            <p>Winches, deck cranes, and complete hydraulic systems</p>
            <span class="stock-card-cta">Explore →</span>
          </div>
        </a>
        <a href="/products" class="stock-card">
          <div class="stock-card-img">
            <img src="/images/anchor-chain.jpg" alt="Anchor and Chain" loading="lazy" />
          </div>
          <div class="stock-card-overlay">
            <span class="stock-card-tag">Deck Spares</span>
            <h3>Anchor and Chain</h3>
            <p>Quality anchors and chains for various ship sizes</p>
            <span class="stock-card-cta">Explore →</span>
          </div>
        </a>
      </div>


    </div>
  </section>

  <!-- Major Brands Marquee -->
  <section class="brands-section">
    <div class="container">
      <h2 class="brands-title reveal">MAJOR BRANDS WE CARRY</h2>
    </div>
    <div class="brands-marquee">
      <div class="brands-track">
        <img src="/images/brands/yanmar-1.svg" alt="Yanmar" class="brand-logo" />
        <img src="/images/brands/caterpillar-logo2.svg" alt="Caterpillar" class="brand-logo" />
        <img src="/images/brands/man-logo.svg" alt="MAN" class="brand-logo" />
        <img src="/images/brands/wartsila.svg" alt="Wartsila" class="brand-logo" />
        <img src="/images/brands/rolls-royce.svg" alt="Rolls-Royce" class="brand-logo" />
        <img src="/images/brands/mtu-friedrichshafen-logo.svg" alt="MTU" class="brand-logo" />
        <img src="/images/brands/cummins.svg" alt="Cummins" class="brand-logo" />
        <img src="/images/brands/mitsubishi-1.svg" alt="Mitsubishi" class="brand-logo" />
        <img src="/images/brands/daihatsu-3.svg" alt="Daihatsu" class="brand-logo" />
        <img src="/images/brands/detroit-diesel-logo.svg" alt="Detroit Diesel" class="brand-logo" />
        
        <!-- Duplicate for seamless loop -->
        <img src="/images/brands/yanmar-1.svg" alt="Yanmar" class="brand-logo" />
        <img src="/images/brands/caterpillar-logo2.svg" alt="Caterpillar" class="brand-logo" />
        <img src="/images/brands/man-logo.svg" alt="MAN" class="brand-logo" />
        <img src="/images/brands/wartsila.svg" alt="Wartsila" class="brand-logo" />
        <img src="/images/brands/rolls-royce.svg" alt="Rolls-Royce" class="brand-logo" />
        <img src="/images/brands/mtu-friedrichshafen-logo.svg" alt="MTU" class="brand-logo" />
        <img src="/images/brands/cummins.svg" alt="Cummins" class="brand-logo" />
        <img src="/images/brands/mitsubishi-1.svg" alt="Mitsubishi" class="brand-logo" />
        <img src="/images/brands/daihatsu-3.svg" alt="Daihatsu" class="brand-logo" />
        <img src="/images/brands/detroit-diesel-logo.svg" alt="Detroit Diesel" class="brand-logo" />
      </div>
    </div>
  </section>

  <!-- Our Services -->
  <section class="section services-section">
    <div class="container">
      <h2 class="section-title reveal" style="color:#222;">OUR SERVICES</h2>
      <p class="section-subtitle reveal">Supplying quality marine engine parts & equipment worldwide</p>
      <div class="services-grid reveal-stagger">
        <a href="/services" class="service-card">
          <div class="service-icon"><Icon name="layer-group" size={40} /></div>
          <h3>Marine Engine Parts Supply</h3>
          <p>Supply and export of all kinds of reconditioned marine engine spare parts — pistons, liners, bearings, valves, gaskets, turbochargers, fuel pumps and more.</p>
        </a>
        <a href="/services" class="service-card">
          <div class="service-icon"><Icon name="tools" size={40} /></div>
          <h3>Engine Overhaul & Reconditioning</h3>
          <p>Complete engine disassembly, inspection, cleaning, reconditioning and testing for Yanmar, Daihatsu, Caterpillar and all major marine engine brands.</p>
        </a>
        <a href="/services" class="service-card">
          <div class="service-icon"><Icon name="globe" size={40} /></div>
          <h3>Worldwide Parts Export</h3>
          <p>Reliable worldwide export of marine engines, generator sets, hydraulic equipment and all engine spare parts from our Chattogram ship-breaking yard hub.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Workshop & Facility -->
  <section class="workshop-section">
    <img src="/images/workshop-facility.webp" alt="Marine Engine Workshop Facility" class="ws-bg" loading="lazy" width="1200" height="1200" />
    <div class="ws-overlay"></div>
    <div class="container ws-content">
      <div class="ws-text reveal-left">
        <span class="ws-label">Our Workshop & Facility</span>
        <h2 class="ws-headline">WE STOCK<br/>AND<br/>EXPORT</h2>
        <p class="ws-desc">Tahin spare suppliers is a leading stockist and global exporter of new, reconditioned and used marine engine and spare parts.</p>
        <div class="ws-highlights">
          <div class="ws-highlight-item">
            <Icon name="tools" size={20} class="ws-hl-icon" />
            <span>Expert Reconditioning</span>
          </div>
          <div class="ws-highlight-item">
            <Icon name="check" size={20} class="ws-hl-icon" />
            <span>Quality Tested</span>
          </div>
          <div class="ws-highlight-item">
            <Icon name="globe" size={20} class="ws-hl-icon" />
            <span>Global Export</span>
          </div>
        </div>
        <a href="/enquiry" class="btn btn-quote">Request a Quote</a>
      </div>
    </div>
  </section>

  <!-- Equipments & Services CTA -->
  <section class="product-services">
    <div class="ps-overlay"></div>
    <div class="container ps-content">
      <h2 class="ps-title reveal-scale">Looking for Marine Equipment?</h2>
      <p class="ps-contact reveal">Call us: +88-01674784019 / +88-01710917904 or Email: tahinship@gmail.com</p>
      <div class="ps-carousel reveal">
        <div class="ps-carousel-track">
          <div class="ps-card">
            <img src="/images/marine-engine.webp" alt="Marine Engine" loading="lazy" />
          </div>
          <div class="ps-card">
            <img src="/images/diesel-generator.webp" alt="Diesel Generator" loading="lazy" />
          </div>
          <div class="ps-card">
            <img src="/images/turbocharger.webp" alt="Turbocharger" loading="lazy" />
          </div>
          <div class="ps-card">
            <img src="/images/hydraulic-crane.webp" alt="Hydraulic Crane" loading="lazy" />
          </div>
          <div class="ps-card">
            <img src="/images/spare-parts.webp" alt="Spare Parts" loading="lazy" />
          </div>
        </div>
        <button class="ps-nav ps-prev" aria-label="Previous"><Icon name="chevron-left" size={16} /></button>
        <button class="ps-nav ps-next" aria-label="Next"><Icon name="chevron-right" size={16} /></button>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section why-choose">
    <div class="container">
      <div class="why-grid">
        <div class="why-accordion reveal-left">
          <h2 class="why-title">WHY CHOOSE US?</h2>
          <div class="accordion-item">
            <button class="accordion-btn active">
              <Icon name="plus" size={12} class="acc-plus" />
              <span>Ready inventory & large stock</span>
              <Icon name="chevron-right" size={12} class="accordion-arrow" />
            </button>
            <div class="accordion-content open">
              <p>We maintain one of the largest inventories of reconditioned marine engines, generators, and spare parts in Bangladesh, sourced directly from the Chattogram Ship-Breaking Yards. Ready stock available for immediate dispatch.</p>
            </div>
          </div>
          <div class="accordion-item">
            <button class="accordion-btn">
              <Icon name="plus" size={12} class="acc-plus" />
              <span>Specialized in top brands</span>
              <Icon name="chevron-right" size={12} class="accordion-arrow" />
            </button>
            <div class="accordion-content">
              <p>We specialize in Yanmar, Daihatsu, and Caterpillar marine engines and generators. Our team has deep expertise in these brands, ensuring you get properly reconditioned, tested equipment.</p>
            </div>
          </div>
          <div class="accordion-item">
            <button class="accordion-btn">
              <Icon name="plus" size={12} class="acc-plus" />
              <span>Skilled workforce & quality testing</span>
              <Icon name="chevron-right" size={12} class="accordion-arrow" />
            </button>
            <div class="accordion-content">
              <p>Every item is carefully inspected, tested, and reconditioned by our experienced technicians before shipping. We guarantee functionality and reliability of all our products.</p>
            </div>
          </div>
          <div class="accordion-item">
            <button class="accordion-btn">
              <Icon name="plus" size={12} class="acc-plus" />
              <span>Worldwide export & timely delivery</span>
              <Icon name="chevron-right" size={12} class="accordion-arrow" />
            </button>
            <div class="accordion-content">
              <p>We export marine equipment worldwide. Our logistics team ensures prompt processing and shipping through reliable international carriers, delivering to your location on time.</p>
            </div>
          </div>
        </div>
        <div class="why-badge reveal-right">
          <img src="/images/satisfaction.webp" alt="100% Customer Satisfaction Guaranteed" />
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    min-height: 700px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    will-change: transform;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      rgba(30, 40, 60, 0.68) 0%,
      rgba(25, 35, 55, 0.45) 40%,
      rgba(15, 25, 45, 0.18) 100%
    );
    z-index: 1;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 60px;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    animation: heroFadeIn 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(35px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  .hero-title {
    color: #fff;
    font-size: 52px;
    font-weight: 800;
    line-height: 1.12;
    margin-bottom: 24px;
    font-family: var(--font-inter), 'Inter', sans-serif;
    text-shadow: 0 4px 30px rgba(0,0,0,0.35);
    text-transform: uppercase;
    letter-spacing: -0.5px;
    max-width: 700px;
  }
  .hero-subtitle {
    font-size: 16px;
    font-weight: 400;
    color: rgba(255,255,255,0.88);
    line-height: 1.7;
    margin-bottom: 32px;
    max-width: 500px;
    font-style: italic;
  }

  /* Request a Quote Button — Copper/Brown */
  .btn-quote {
    display: inline-block;
    padding: 14px 36px;
    background: linear-gradient(135deg, #a67c52, #8b6240);
    color: #fff;
    font-size: 15px;
    font-weight: 600;
    border-radius: 6px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(139, 98, 64, 0.4);
    width: fit-content;
  }
  .btn-quote:hover {
    background: linear-gradient(135deg, #b98a5c, #9a7050);
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(139, 98, 64, 0.55);
  }
  .btn-quote:active {
    transform: translateY(0);
  }

  /* Spare Parts Strip */
  .parts-strip {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
    gap: 0;
    background: rgba(245, 245, 245, 0.95);
    backdrop-filter: blur(10px);
    margin-top: auto;
  }
  .parts-strip-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    overflow: hidden;
    cursor: pointer;
    position: relative;
    border-right: 1px solid rgba(0,0,0,0.08);
    transition: background 0.3s ease;
  }
  .parts-strip-item:last-child {
    border-right: none;
  }
  .parts-strip-item:hover {
    background: rgba(230, 230, 230, 0.95);
  }
  .parts-strip-item img {
    width: 100%;
    height: 120px;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.33, 1, 0.68, 1);
  }
  .parts-strip-item:hover img {
    transform: scale(1.08);
  }
  .parts-label {
    display: block;
    padding: 8px 6px;
    font-size: 12px;
    font-weight: 600;
    color: #fff;
    text-align: center;
    background: rgba(50, 50, 60, 0.85);
    width: 100%;
    letter-spacing: 0.3px;
    text-transform: capitalize;
    backdrop-filter: blur(4px);
  }



  /* Who We Are */
  .who-we-are {
    text-align: center;
    background: #fff;
  }
  .who-desc {
    max-width: 850px;
    margin: 0 auto;
    font-size: 15px;
    color: #555;
    line-height: 1.8;
  }

  /* Stock Spares / Products — Premium Overlay Cards */
  /* Brands Marquee */
  .brands-section {
    padding: 60px 0 50px;
    background: #fff;
    overflow: hidden;
    border-bottom: 1px solid #eee;
    border-top: 1px solid #eee;
  }
  .brands-title {
    text-align: center;
    font-size: 22px;
    font-weight: 700;
    color: #222;
    margin-bottom: 40px;
    letter-spacing: 2px;
  }
  .brands-marquee {
    overflow: hidden;
    position: relative;
    padding: 10px 0;
  }
  .brands-marquee::before,
  .brands-marquee::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 150px;
    z-index: 2;
  }
  .brands-marquee::before {
    left: 0;
    background: linear-gradient(to right, #fff, transparent);
  }
  .brands-marquee::after {
    right: 0;
    background: linear-gradient(to left, #fff, transparent);
  }
  .brands-track {
    display: flex;
    gap: 80px;
    animation: marquee-scroll 35s linear infinite;
    width: max-content;
    align-items: center;
  }
  .brand-logo {
    height: 45px;
    width: auto;
    max-width: 160px;
    object-fit: contain;
    opacity: 0.9;
    transition: all 0.4s ease;
  }
  .brand-logo:hover {
    opacity: 1;
    transform: scale(1.05);
  }
  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .stock-spares {
    background: #f9f9f9;
  }
  .stock-title {
    text-align: center;
    font-size: 28px;
    font-weight: 700;
    color: #222;
    margin-bottom: 8px;
  }
  .stock-subtitle {
    text-align: center;
    color: #c0392b;
    font-size: 15px;
    margin-bottom: 40px;
    font-weight: 500;
  }
  .stock-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .stock-card {
    position: relative;
    display: block;
    height: 280px;
    border-radius: 16px;
    overflow: hidden;
    cursor: pointer;
    color: #fff;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    transition: transform 0.5s cubic-bezier(0.33, 1, 0.68, 1),
                box-shadow 0.5s ease;
    will-change: transform;
  }
  .stock-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 20px 50px rgba(0,0,0,0.25);
  }
  .stock-card-img {
    position: absolute;
    inset: 0;
  }
  .stock-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.33, 1, 0.68, 1),
                filter 0.5s ease;
  }
  .stock-card:hover .stock-card-img img {
    transform: scale(1.15);
    filter: brightness(0.6);
  }
  .stock-card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 24px 20px;
    background: linear-gradient(
      to top,
      rgba(10, 10, 30, 0.9) 0%,
      rgba(10, 10, 30, 0.4) 50%,
      transparent 100%
    );
    transition: background 0.5s ease;
  }
  .stock-card:hover .stock-card-overlay {
    background: linear-gradient(
      to top,
      rgba(10, 10, 30, 0.95) 0%,
      rgba(10, 10, 30, 0.6) 60%,
      rgba(10, 10, 30, 0.2) 100%
    );
  }
  .stock-card-tag {
    display: inline-block;
    background: rgba(192, 57, 43, 0.85);
    color: #fff;
    padding: 3px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 10px;
    width: fit-content;
    backdrop-filter: blur(4px);
    transition: background 0.3s, transform 0.4s cubic-bezier(0.33, 1, 0.68, 1);
  }
  .stock-card:hover .stock-card-tag {
    background: #c0392b;
    transform: translateY(-3px);
  }
  .stock-card h3 {
    font-size: 17px;
    font-weight: 700;
    margin-bottom: 6px;
    line-height: 1.3;
    transition: transform 0.4s cubic-bezier(0.33, 1, 0.68, 1);
  }
  .stock-card:hover h3 {
