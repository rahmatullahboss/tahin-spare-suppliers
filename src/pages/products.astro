---
import MainLayout from '../layouts/MainLayout.astro';
import { getRuntimeEnv } from '../lib/server/env';
import { listContent } from '../lib/server/repository';

const products = [
  {
    name: 'Yanmar 6N18AL Marine Diesel Engine',
    category: 'Marine Propulsion Engine',
    image: '/images/marine-propulsion-engine.jpg',
    link: '/marine-propulsion-engines'
  },
  {
    name: '500 KVA Caterpillar Diesel Generator Set',
    category: 'Diesel & Gas Generator Set',
    image: '/images/diesel-generator-set.jpg',
    link: '/diesel-generator-sets'
  },
  {
    name: 'Hydraulic Luffing Winch System',
    category: 'Hydraulic Deck Crane Equipment',
    image: '/images/hydraulic-crane-equipment.jpg',
    link: '/hydraulic-crane-equipment'
  },
  {
    name: 'Marine Gearbox - Various Models',
    category: 'Marine Gearbox',
    image: '/images/marine-gearbox.jpg',
    link: '/marine-gearbox'
  },
  {
    name: 'Engine Spare Parts — Pistons, Liners, Bearings',
    category: 'Spare Parts',
    image: '/images/spare-parts-new.jpg',
    link: '/marine-spare-parts'
  },
  {
    name: 'Daihatsu 6DK-20 Auxiliary Engine',
    category: 'Auxiliary Engine',
    image: '/images/auxiliary-engine.jpg',
    link: '/marine-auxillary-engines'
  },
  {
    name: 'Anchor and Chain Set',
    category: 'Anchor and Chain',
    image: '/images/anchor-chain.jpg',
    link: '/anchor-and-chain'
  },
  {
    name: 'Marine Water Pump',
    category: 'Marine Pump',
    image: '/images/marine-pump.jpg',
    link: '/products'
  }
];

const categories = ['All Equipments', 'Marine Propulsion Engine', 'Marine Gearbox', 'Auxiliary Engine', 'Diesel & Gas Generator Set', 'Spare Parts', 'Hydraulic Deck Crane Equipment', 'Anchor and Chain', 'Marine Pump'];
const env = getRuntimeEnv(Astro.locals);
const liveProducts = await listContent(env, 'products');
---
<MainLayout title="Equipments - Tahin Spare Suppliers" activeNav="products">
  <section class="page-hero">
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <h1 class="reveal">Our Equipments</h1>
      <p class="hero-subtitle reveal">Your one-stop solution for reconditioned marine engines & equipment</p>
      <p class="reveal">Home / Equipments</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="products-intro reveal">As a full-range supplier, Tahin Spare Suppliers has access to a complete spectrum of reconditioned marine engines, generator sets, auxiliary engines, hydraulic equipment, and spare parts from the top brands.</p>

      <div class="filter-tabs reveal" id="filter-tabs">
        {categories.map((cat) => (
          <button class:list={['filter-btn', { active: cat === 'All Equipments' }]} data-category={cat}>
            {cat}
          </button>
        ))}
      </div>

      <div class="products-grid reveal-stagger" id="products-grid">
        {products.map((product) => (
          <a href={product.link} class="product-card" data-category={product.category} style="text-decoration: none;">
            <div class="product-img">
              <img src={product.image} alt={product.name} loading="lazy" />
            </div>
            <div class="product-content">
              <h3>{product.name}</h3>
              <span class="view-details">VIEW DETAILS</span>
            </div>
          </a>
        ))}
      </div>

      {liveProducts.length > 0 && (
        <>
          <h2 class="live-section-title">Client-Managed Products</h2>
          <div class="products-grid live-products-grid">
            {liveProducts.map((product) => (
              <a href={`/products/${product.slug}`} class="product-card" style="text-decoration: none;">
                <div class="product-img">
                  <img src={product.imageUrl || '/images/marine-engine.webp'} alt={product.title} loading="lazy" />
                </div>
                <div class="product-content">
                  <h3>{product.title}</h3>
                  <p class="live-excerpt">{product.excerpt}</p>
                  <span class="view-details">VIEW DETAILS</span>
                </div>
              </a>
            ))}
          </div>
        </>
      )}

      <div class="products-cta">
        <p>Can't find what you're looking for? <a href="/enquiry">Send us an enquiry</a> and we'll check our inventory.</p>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-hero {
    position: relative;
    height: 350px;
    background: url('/images/services-hero.jpg') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .page-hero-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); }
  .page-hero-content { position: relative; z-index: 1; color: #fff; }
  .page-hero-content h1 { font-size: 36px; font-weight: 700; margin-bottom: 8px; }
  .page-hero-content p { font-size: 14px; color: #ddd; }

  .products-intro {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 30px;
    font-size: 15px;
    color: #555;
    line-height: 1.7;
  }

  .filter-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 30px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .filter-btn {
    padding: 8px 20px;
    border: 1px solid #ddd;
    background: #fff;
    border-radius: 4px;
    font-size: 13px;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    transition: all 0.3s;
    color: #555;
  }
  .filter-btn:hover,
  .filter-btn.active {
    background: #c0392b;
    color: #fff;
    border-color: #c0392b;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .product-card {
    position: relative;
    border-radius: 0;
    background: #fff;
    border: 1px solid #eaeaea;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.04);
    transition: transform 0.35s ease, box-shadow 0.35s ease;
    cursor: pointer;
    display: flex;
    flex-direction: column;
  }
  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 35px rgba(0,0,0,0.1);
  }
  .product-card.hidden { display: none; }
  .product-img {
    width: 100%;
    height: 240px;
    position: relative;
    overflow: hidden;
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 92%);
  }
  .product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .product-card:hover .product-img img {
    transform: scale(1.06);
  }
  .product-content {
    padding: 24px 24px 30px;
    background: #fff;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .product-content h3 {
    font-size: 20px;
    color: #111;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 20px;
    font-family: var(--font-inter), 'Inter', sans-serif;
  }
  .view-details {
    font-size: 13px;
    color: #e67e22;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: color 0.3s;
  }
  .product-card:hover .view-details {
    color: #c0392b;
  }

  .products-cta {
    text-align: center;
    margin-top: 40px;
    font-size: 15px;
    color: #555;
  }
  .live-section-title {
    margin: 50px 0 24px;
    text-align: center;
    font-size: 28px;
    color: #222;
  }
  .live-excerpt {
    margin: 0 0 16px;
    color: #666;
    line-height: 1.7;
  }
  .products-cta a {
    color: #c0392b;
    font-weight: 600;
    text-decoration: underline;
  }
  .products-cta a:hover {
    color: #a93226;
  }

  @media (max-width: 768px) {
    .products-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .products-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const category = (btn as HTMLElement).dataset.category;
      document.querySelectorAll('.product-card').forEach(card => {
        if (category === 'All Equipments' || (card as HTMLElement).dataset.category === category) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
