---
import MainLayout from '../layouts/MainLayout.astro';

const products = [
  {
    name: 'Yanmar 6N18AL Marine Diesel Engine',
    category: 'Marine Propulsion Engine',
    image: '/images/marine-engine.webp',
  },
  {
    name: '500 KVA Caterpillar Diesel Generator Set',
    category: 'Diesel & Gas Generator Set',
    image: '/images/diesel-generator-set.jpg',
  },
  {
    name: 'Hydraulic Luffing Winch System',
    category: 'Hydraulic Deck Crane Equipment',
    image: '/images/hydraulic-crane-equipment.jpg',
  },
  {
    name: 'Marine Gearbox - Various Models',
    category: 'Marine Gearbox',
    image: '/images/marine-gearbox.jpg',
  },
  {
    name: 'Marine Water Pump & Air Compressor',
    category: 'Spare Parts',
    image: '/images/pump-compressor.webp',
  },
  {
    name: 'Fresh Water Generator & Heat Exchanger',
    category: 'Spare Parts',
    image: '/images/heat-exchanger.webp',
  },
  {
    name: 'Engine Spare Parts — Pistons, Liners, Bearings',
    category: 'Spare Parts',
    image: '/images/spare-parts-new.jpg',
  },
  {
    name: 'Daihatsu 6DK-20 Auxiliary Engine',
    category: 'Auxiliary Engine',
    image: '/images/auxiliary-engine.jpg',
  },
  {
    name: 'Caterpillar 3512 Marine Propulsion Engine',
    category: 'Marine Propulsion Engine',
    image: '/images/marine-engine.webp',
  },
  {
    name: '150 KVA Caterpillar Diesel Generator',
    category: 'Diesel & Gas Generator Set',
    image: '/images/diesel-generator-set.jpg',
  },
  {
    name: 'Anchor and Chain Set',
    category: 'Anchor and Chain',
    image: '/images/anchor-chain.jpg',
  },
  {
    name: 'MHI MET Marine Turbocharger',
    category: 'Turbochargers',
    image: '/images/turbocharger.webp',
  },
];

const categories = ['All Equipments', 'Marine Propulsion Engine', 'Marine Gearbox', 'Auxiliary Engine', 'Diesel & Gas Generator Set', 'Spare Parts', 'Hydraulic Deck Crane Equipment', 'Anchor and Chain'];
---
<MainLayout title="Equipments - Tahin Spare Suppliers" activeNav="products">
  <section class="page-hero">
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <h1 class="reveal">Our Equipments</h1>
      <p class="hero-subtitle reveal">Your one-stop solution for reconditioned marine engines & equipment</p>
      <p class="reveal">Home / Equipments</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="products-intro reveal">As a full-range supplier, Tahin Spare Suppliers has access to a complete spectrum of reconditioned marine engines, generator sets, auxiliary engines, hydraulic equipment, and spare parts from the top brands.</p>

      <div class="filter-tabs reveal" id="filter-tabs">
        {categories.map((cat) => (
          <button class:list={['filter-btn', { active: cat === 'All Equipments' }]} data-category={cat}>
            {cat}
          </button>
        ))}
      </div>

      <div class="products-grid reveal-stagger" id="products-grid">
        {products.map((product) => (
          <div class="product-card" data-category={product.category}>
            <div class="product-img">
              <img src={product.image} alt={product.name} loading="lazy" />
            </div>
            <div class="product-overlay">
              <span class="product-cat">{product.category}</span>
              <h3>{product.name}</h3>
            </div>
          </div>
        ))}
      </div>

      <div class="products-cta">
        <p>Can't find what you're looking for? <a href="/enquiry">Send us an enquiry</a> and we'll check our inventory.</p>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-hero {
    position: relative;
    height: 250px;
    background: url('/images/hero-bg.webp') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .page-hero-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); }
  .page-hero-content { position: relative; z-index: 1; color: #fff; }
  .page-hero-content h1 { font-size: 36px; font-weight: 700; margin-bottom: 8px; }
  .page-hero-content p { font-size: 14px; color: #ddd; }

  .products-intro {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 30px;
    font-size: 15px;
    color: #555;
    line-height: 1.7;
  }

  .filter-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 30px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .filter-btn {
    padding: 8px 20px;
    border: 1px solid #ddd;
    background: #fff;
    border-radius: 4px;
    font-size: 13px;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    transition: all 0.3s;
    color: #555;
  }
  .filter-btn:hover,
  .filter-btn.active {
    background: #c0392b;
    color: #fff;
    border-color: #c0392b;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .product-card {
    position: relative;
    height: 300px;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    transition: transform 0.35s ease, box-shadow 0.35s ease;
    cursor: pointer;
  }
  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 35px rgba(0,0,0,0.15);
  }
  .product-card.hidden { display: none; }
  .product-img {
    position: absolute;
    inset: 0;
  }
  .product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .product-card:hover .product-img img {
    transform: scale(1.06);
  }
  .product-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px;
    background: linear-gradient(
      to top,
      rgba(26, 26, 46, 0.92) 0%,
      rgba(26, 26, 46, 0.5) 60%,
      transparent 100%
    );
    color: #fff;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 50%;
  }
  .product-overlay h3 {
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
    margin-top: 4px;
  }
  .product-cat {
    font-size: 11px;
    color: #c0392b;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    background: rgba(255,255,255,0.12);
    padding: 2px 10px;
    border-radius: 3px;
    width: fit-content;
  }

  .products-cta {
    text-align: center;
    margin-top: 40px;
    font-size: 15px;
    color: #555;
  }
  .products-cta a {
    color: #c0392b;
    font-weight: 600;
    text-decoration: underline;
  }
  .products-cta a:hover {
    color: #a93226;
  }

  @media (max-width: 768px) {
    .products-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .products-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const category = (btn as HTMLElement).dataset.category;
      document.querySelectorAll('.product-card').forEach(card => {
        if (category === 'All Equipments' || (card as HTMLElement).dataset.category === category) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
