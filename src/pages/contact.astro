---
import MainLayout from '../layouts/MainLayout.astro';
import Icon from '../components/Icon.astro';
---
<MainLayout title="Contact Us - Tahin Spare Suppliers" activeNav="contact">
  <section class="page-hero">
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <h1>Contact Us</h1>
      <p>Home / Contact Us</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid reveal-stagger">
        <div class="contact-card">
          <Icon name="map-marker-alt" size={36} class="contact-icon" />
          <h3>Our Location</h3>
          <p>Kadamrasul (Saleh Carpet), D.T. Road</p>
          <p>Bhatiary, Sitakunda, Chattogram</p>
          <p>Bangladesh (Near Scrap Ship Yard)</p>
        </div>
        <div class="contact-card">
          <Icon name="phone-alt" size={36} class="contact-icon" />
          <h3>Call Us</h3>
          <p><a href="tel:+8801674784019">+88-01674784019</a></p>
          <p><a href="tel:+8801710917904">+88-01710917904</a></p>
          <p>Available: Sat - Thu</p>
        </div>
        <div class="contact-card">
          <Icon name="envelope" size={36} class="contact-icon" />
          <h3>Email Us</h3>
          <p><a href="mailto:tahinship@gmail.com">tahinship@gmail.com</a></p>
          <p>We reply within 24 hours</p>
        </div>
      </div>

      <div class="contact-form-section reveal">
        <h2>Send Us a Message</h2>
        <form class="contact-form">
          <div class="form-row">
            <div class="form-group">
              <input type="text" placeholder="Your Name" required />
            </div>
            <div class="form-group">
              <input type="email" placeholder="Your Email" required />
            </div>
          </div>
          <div class="form-group">
            <input type="text" placeholder="Subject" required />
          </div>
          <div class="form-group">
            <textarea rows="6" placeholder="Your Message" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Send Message</button>
        </form>
      </div>

      <div class="map-section">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d14720!2d91.66!3d22.62!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x30acd6f2e6ef3e07%3A0x552e33a8aee861e9!2sSitakunda!5e0!3m2!1sen!2sbd!4v1700000000000!5m2!1sen!2sbd"
          width="100%"
          height="400"
          style="border:0; border-radius:10px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Our Location - Sitakunda, Chattogram, Bangladesh">
        </iframe>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-hero {
    position: relative;
    height: 250px;
    background: url('/images/hero-bg.webp') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .page-hero-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); }
  .page-hero-content { position: relative; z-index: 1; color: #fff; }
  .page-hero-content h1 { font-size: 36px; font-weight: 700; margin-bottom: 8px; }
  .page-hero-content p { font-size: 14px; color: #ddd; }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 25px;
    margin-bottom: 50px;
  }
  .contact-card {
    text-align: center;
    padding: 40px 20px;
    background: #f9f9f9;
    border-radius: 10px;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .contact-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }
  .contact-card :global(.contact-icon) {
    color: #c0392b;
    margin-bottom: 15px;
  }
  .contact-card h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 10px;
    color: #222;
  }
  .contact-card p {
    font-size: 14px;
    color: #666;
    margin-bottom: 3px;
  }
  .contact-card a {
    color: #c0392b;
    text-decoration: none;
    font-weight: 500;
  }
  .contact-card a:hover {
    text-decoration: underline;
  }

  .contact-form-section {
    max-width: 700px;
    margin: 0 auto 50px;
  }
  .contact-form-section h2 {
    text-align: center;
    font-size: 28px;
    font-weight: 700;
    color: #222;
    margin-bottom: 30px;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
  }
  .form-group {
    margin-bottom: 15px;
  }
  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 14px;
    font-family: var(--font-inter), 'Inter', sans-serif;
    transition: border-color 0.3s;
  }
  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #c0392b;
  }

  .map-section {
    margin-top: 20px;
  }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
