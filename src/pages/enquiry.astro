---
import MainLayout from '../layouts/MainLayout.astro';
import Icon from '../components/Icon.astro';
---
<MainLayout title="Enquiry - Tahin Spare Suppliers" activeNav="enquiry">
  <section class="page-hero">
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <h1>Request a Quote</h1>
      <p>Home / Enquiry</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="enquiry-grid">
        <div class="enquiry-info reveal-left">
          <h2>Make an Enquiry</h2>
          <p>Looking for specific marine engines, generators, spare parts or equipment? Fill out the form and our team will get back to you with a price quote within 24 hours.</p>
          <div class="info-items">
            <div class="info-item">
              <Icon name="whatsapp" size={20} class="info-icon whatsapp-info-icon" />
              <div>
                <h4>WhatsApp</h4>
                <p><a href="https://wa.me/8801787429268" target="_blank" rel="noopener">+880 1787-429268</a></p>
              </div>
            </div>
            <div class="info-item">
              <Icon name="phone-alt" size={20} class="info-icon" />
              <div>
                <h4>Call Us</h4>
                <p>+88-01710917904</p>
              </div>
            </div>
            <div class="info-item">
              <Icon name="envelope" size={20} class="info-icon" />
              <div>
                <h4>Email Us</h4>
                <p>tahinship@gmail.com</p>
              </div>
            </div>
            <div class="info-item">
              <Icon name="map-marker-alt" size={20} class="info-icon" />
              <div>
                <h4>Our Location</h4>
                <p><a href="https://maps.app.goo.gl/3wovmfX2FxXH5ymn9?g_st=aw" target="_blank" rel="noopener">Kadamrasul (Saleh Carpet), D.T. Road, Bhatiary, Sitakunda, Chattogram, Bangladesh</a></p>
              </div>
            </div>
            <div class="info-item">
              <Icon name="clock" size={20} class="info-icon" />
              <div>
                <h4>Working Hours</h4>
                <p>Sat - Thu: 9:00 AM - 6:00 PM</p>
              </div>
            </div>
          </div>
        </div>
        <div class="enquiry-form-wrap reveal-right">
          <form class="enquiry-form" id="enquiry-form" action="/api/enquiry" method="POST">
            <input type="text" name="_gotcha" style="display:none" />
            <div class="form-group">
              <label for="name">Your Name *</label>
              <input type="text" id="name" name="name" required placeholder="Enter your name" />
            </div>
            <div class="form-group">
              <label for="email">Email Address *</label>
              <input type="email" id="email" name="email" required placeholder="Enter your email" />
            </div>
            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone" placeholder="Enter your phone number" />
            </div>
            <div class="form-group">
              <label for="equipment">Equipment Category</label>
              <select id="equipment" name="equipment">
                <option value="">Select a category</option>
                <option value="Marine Propulsion Engine">Marine Propulsion Engine</option>
                <option value="Marine Gearbox">Marine Gearbox</option>
                <option value="Auxiliary Engine">Auxiliary Engine</option>
                <option value="Diesel & Gas Generator Set">Diesel & Gas Generator Set</option>
                <option value="Spare Parts">Spare Parts</option>
                <option value="Hydraulic Deck Crane Equipment">Hydraulic Deck Crane Equipment</option>
                <option value="Anchor and Chain">Anchor and Chain</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div class="form-group full-width">
              <label for="message">Your Message *</label>
              <textarea id="message" name="message" rows="5" required placeholder="Describe the parts or equipment you need, including model numbers if available..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary" id="submit-btn">Send Enquiry</button>
            <div class="form-status" id="form-status"></div>
          </form>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  const form = document.getElementById('enquiry-form') as HTMLFormElement;
  const statusEl = document.getElementById('form-status') as HTMLElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    statusEl.className = 'form-status';
    statusEl.textContent = '';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' }
      });

      if (res.ok) {
        statusEl.textContent = '✅ Your enquiry has been sent successfully! We will get back to you within 24 hours.';
        statusEl.className = 'form-status success';
        form.reset();
      } else {
        statusEl.textContent = '❌ Something went wrong. Please try again or email us directly at tahinship@gmail.com';
        statusEl.className = 'form-status error';
      }
    } catch {
      statusEl.textContent = '❌ Network error. Please try again or email us directly at tahinship@gmail.com';
      statusEl.className = 'form-status error';
    }

    submitBtn.disabled = false;
    submitBtn.textContent = 'Send Enquiry';
  });
</script>

<style>
  .page-hero {
    position: relative;
    height: 250px;
    background: url('/images/hero-bg.webp') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .page-hero-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); }
  .page-hero-content { position: relative; z-index: 1; color: #fff; }
  .page-hero-content h1 { font-size: 36px; font-weight: 700; margin-bottom: 8px; }
  .page-hero-content p { font-size: 14px; color: #ddd; }

  .enquiry-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 50px;
  }
  .enquiry-info h2 {
    font-size: 28px;
    font-weight: 700;
    color: #222;
    margin-bottom: 15px;
  }
  .enquiry-info > p {
    font-size: 14px;
    color: #666;
    line-height: 1.7;
    margin-bottom: 30px;
  }
  .info-items { display: flex; flex-direction: column; gap: 20px; }
  .info-item {
    display: flex;
    gap: 15px;
    align-items: flex-start;
  }
  .info-item :global(.info-icon) {
    color: #c0392b;
    margin-top: 3px;
    flex-shrink: 0;
  }
  .info-item :global(.whatsapp-info-icon) {
    color: #25d366;
  }
  .info-item a {
    color: #c0392b;
    text-decoration: none;
    font-weight: 500;
  }
  .info-item a:hover {
    text-decoration: underline;
  }
  .info-item h4 {
    font-size: 15px;
    font-weight: 600;
    color: #222;
    margin-bottom: 3px;
  }
  .info-item p {
    font-size: 14px;
    color: #666;
  }

  .enquiry-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .form-group { display: flex; flex-direction: column; }
  .form-group.full-width { grid-column: 1 / -1; }
  .form-group label {
    font-size: 13px;
    font-weight: 600;
    color: #333;
    margin-bottom: 6px;
  }
  .form-group input,
  .form-group textarea,
  .form-group select {
    padding: 10px 14px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 14px;
    font-family: var(--font-inter), 'Inter', sans-serif;
    transition: border-color 0.3s;
    background: #fff;
  }
  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus {
    outline: none;
    border-color: #c0392b;
  }
  .enquiry-form .btn {
    grid-column: 1 / -1;
    justify-self: start;
  }
  .form-status {
    grid-column: 1 / -1;
    padding: 12px 16px;
    border-radius: 6px;
    font-size: 14px;
    display: none;
  }
  .form-status.success {
    display: block;
    background: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
  }
  .form-status.error {
    display: block;
    background: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
  }

  @media (max-width: 768px) {
    .enquiry-grid { grid-template-columns: 1fr; }
    .enquiry-form { grid-template-columns: 1fr; }
  }
</style>
