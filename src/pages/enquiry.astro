---
import MainLayout from '../layouts/MainLayout.astro';
import Icon from '../components/Icon.astro';
---
<MainLayout title="Enquiry - Tahin Spare Suppliers" activeNav="enquiry">
  <section class="page-hero">
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <h1>Enquiry</h1>
      <p>Home / Enquiry</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="enquiry-grid">
        <div class="enquiry-info">
          <h2>Make an Enquiry</h2>
          <p>Looking for specific marine spare parts or equipment? Fill out the form and our team will get back to you with a price quote within 24 hours.</p>
          <div class="info-items">
            <div class="info-item">
              <Icon name="phone-alt" size={20} class="info-icon" />
              <div>
                <h4>Call Us</h4>
                <p>+880 1674-784019</p>
              </div>
            </div>
            <div class="info-item">
              <Icon name="envelope" size={20} class="info-icon" />
              <div>
                <h4>Email Us</h4>
                <p>tahinship@gmail.com</p>
              </div>
            </div>
            <div class="info-item">
              <Icon name="clock" size={20} class="info-icon" />
              <div>
                <h4>Working Hours</h4>
                <p>Sat - Thu: 9:00 AM - 6:00 PM</p>
              </div>
            </div>
          </div>
        </div>
        <div class="enquiry-form-wrap">
          <form class="enquiry-form">
            <div class="form-group">
              <label for="name">Your Name *</label>
              <input type="text" id="name" name="name" required placeholder="Enter your name" />
            </div>
            <div class="form-group">
              <label for="email">Email Address *</label>
              <input type="email" id="email" name="email" required placeholder="Enter your email" />
            </div>
            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone" placeholder="Enter your phone number" />
            </div>
            <div class="form-group">
              <label for="subject">Subject *</label>
              <input type="text" id="subject" name="subject" required placeholder="What is your enquiry about?" />
            </div>
            <div class="form-group full-width">
              <label for="message">Your Message *</label>
              <textarea id="message" name="message" rows="5" required placeholder="Describe the parts or equipment you need..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Send Enquiry</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-hero {
    position: relative;
    height: 250px;
    background: url('/images/hero-bg.webp') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .page-hero-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); }
  .page-hero-content { position: relative; z-index: 1; color: #fff; }
  .page-hero-content h1 { font-size: 36px; font-weight: 700; margin-bottom: 8px; }
  .page-hero-content p { font-size: 14px; color: #ddd; }

  .enquiry-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 50px;
  }
  .enquiry-info h2 {
    font-size: 28px;
    font-weight: 700;
    color: #222;
    margin-bottom: 15px;
  }
  .enquiry-info > p {
    font-size: 14px;
    color: #666;
    line-height: 1.7;
    margin-bottom: 30px;
  }
  .info-items { display: flex; flex-direction: column; gap: 20px; }
  .info-item {
    display: flex;
    gap: 15px;
    align-items: flex-start;
  }
  .info-item :global(.info-icon) {
    color: #c0392b;
    margin-top: 3px;
    flex-shrink: 0;
  }
  .info-item h4 {
    font-size: 15px;
    font-weight: 600;
    color: #222;
    margin-bottom: 3px;
  }
  .info-item p {
    font-size: 14px;
    color: #666;
  }

  .enquiry-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .form-group { display: flex; flex-direction: column; }
  .form-group.full-width { grid-column: 1 / -1; }
  .form-group label {
    font-size: 13px;
    font-weight: 600;
    color: #333;
    margin-bottom: 6px;
  }
  .form-group input,
  .form-group textarea {
    padding: 10px 14px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 14px;
    font-family: var(--font-inter), 'Inter', sans-serif;
    transition: border-color 0.3s;
  }
  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #c0392b;
  }
  .enquiry-form .btn {
    grid-column: 1 / -1;
    justify-self: start;
  }

  @media (max-width: 768px) {
    .enquiry-grid { grid-template-columns: 1fr; }
    .enquiry-form { grid-template-columns: 1fr; }
  }
</style>
