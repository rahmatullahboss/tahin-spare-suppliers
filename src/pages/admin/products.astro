---
import AdminLayout from "../../layouts/AdminLayout.astro";
import ContentEditor from "../../components/admin/ContentEditor.astro";
import { getRuntimeEnv } from "../../lib/server/env";
import { isAuthenticated } from "../../lib/server/session";

const env = getRuntimeEnv(Astro.locals);
const authenticated = await isAuthenticated(Astro.cookies, env.SESSION_SECRET);

if (!authenticated) {
  return Astro.redirect("/admin/login");
}
---
<AdminLayout title="Manage Products" active="products">
  <ContentEditor
    type="products"
    title="Manage Products"
    itemLabel="Products"
    titleLabel="Product Name"
    excerptLabel="Short Description"
  />
</AdminLayout>
