---
import MainLayout from '../layouts/MainLayout.astro';
import Icon from '../components/Icon.astro';
---
<MainLayout title="About Us - Tahin Spare Suppliers" activeNav="about">
  <section class="page-hero">
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <h1>About Us</h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="about-grid">
        <div class="about-text reveal-left" style="text-align: center;">
          <h2 class="section-title" style="text-align:center;">Who We Are</h2>
          <p style="text-align: center; margin-bottom: 15px;">Tahin Spare Suppliers is a trusted name in the marine and industrial machinery sector, specializing in the supply of high-quality reconditioned, used, and new engines, generators, and spare parts. With years of experience in the industry, we have built a strong reputation for reliability, competitive pricing, and customer satisfaction.</p>
          <p style="text-align: center; margin-bottom: 15px;">Since our establishment, we have been actively sourcing equipment from ship recycling yards and global markets, ensuring a consistent supply of genuine and performance-tested machinery. Every product we offer goes through careful inspection to maintain quality and operational efficiency.</p>
          <p style="text-align: center; margin-bottom: 15px;">Our warehouse is equipped with a wide range of marine engines, diesel generators, and spare parts from leading international brands. Whether for marine use or industrial applications, we are committed to delivering dependable solutions tailored to our clients’ needs.</p>
          <p style="text-align: center;">At Tahin Spare Suppliers, we believe in building long-term relationships with our customers by offering transparent service, flexible pricing, and professional support. Our goal is to be a reliable partner in powering your business operations.</p>
        </div>
        <div class="about-image reveal-right img-zoom">
          <img src="/images/shipping-dock.jpg" alt="Shipping Dock Area" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Proprietor Section -->
  <section class="section proprietor-section" style="background:#fff;">
    <div class="container">
      <div class="proprietor-grid">
        <div class="proprietor-image reveal-left">
          <img src="/images/proprietor.jpg" alt="MD Jamal Uddin - Proprietor" loading="lazy" />
        </div>
        <div class="proprietor-info reveal-right">
          <h2 class="section-title" style="text-align:center; margin-bottom:10px;">MEET OUR PROPRIETOR</h2>
          <h3 class="proprietor-name">MD Jamal Uddin</h3>
          <p class="proprietor-role">Proprietor, Tahin Spare Suppliers</p>
          <div class="proprietor-bio">
            <p>Under the visionary leadership of <strong>MD Jamal Uddin</strong>, Tahin Spare Suppliers has grown into a global name in the marine industry. With decades of experience and deep-rooted connections within the Chattogram Ship-Breaking Hub, he has established a legacy of trust, quality, and reliability.</p>
            <blockquote>"Our commitment is to provide the highest quality reconditioned marine equipment that ensures the safety and efficiency of your maritime operations. We value every client and strive to build long-term partnerships through transparent service and competitive excellence."</blockquote>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Partner With Us -->
  <section class="section" style="background:#f9f9f9;">
    <div class="container">
      <h2 class="section-title">WHY PARTNER WITH US</h2>
      <p class="section-subtitle" style="color:#555;">What makes Tahin Spare Suppliers your reliable partner</p>
      <div class="strength-grid reveal-stagger">
        <div class="strength-card">
          <Icon name="map-marker-alt" size={40} class="strength-icon" />
          <h3>Direct Sourcing</h3>
          <p>Being located at the source (Chattogram Ship-Breaking Hub), we offer the most competitive prices in the international market.</p>
        </div>
        <div class="strength-card">
          <Icon name="warehouse" size={40} class="strength-icon" />
          <h3>Ready-to-Ship Stock</h3>
          <p>We maintain a large inventory at our Bhatiari warehouse, allowing for quick response times and physical or video inspections before purchase.</p>
        </div>
        <div class="strength-card">
          <Icon name="globe" size={40} class="strength-icon" />
          <h3>Global Reach</h3>
          <p>Experienced in facilitating worldwide shipping via air or sea freight, ensuring your spares reach your vessel's next port of call.</p>
        </div>
        <div class="strength-card">
          <Icon name="check-circle" size={40} class="strength-icon" />
          <h3>Transparency & Trust</h3>
          <p>We provide detailed photos, load test videos, and technical reports to ensure full client satisfaction before shipping.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Offer -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">WHAT WE OFFER</h2>
      <p class="section-subtitle" style="color:#555;">Complete range of marine equipment and spare parts</p>
      <div class="offer-grid">
        <div class="offer-card">
          <Icon name="cogs" size={36} class="offer-icon" />
          <h3>Marine Propulsion Engine</h3>
          <p>Main propulsion engines from Yanmar, Daihatsu, Caterpillar, MAN B&W, Sulzer, MAK, Deutz, MWM, MTU, SKL.</p>
        </div>
        <div class="offer-card">
          <Icon name="industry" size={36} class="offer-icon" />
          <h3>Marine Gearbox</h3>
          <p>High-quality reconditioned marine gearboxes for various engine models and sizes.</p>
        </div>
        <div class="offer-card">
          <Icon name="fan" size={36} class="offer-icon" />
          <h3>Auxiliary Engine</h3>
          <p>Reliable auxiliary engines for onboard power generation and machinery operation.</p>
        </div>
        <div class="offer-card">
          <Icon name="bolt" size={36} class="offer-icon" />
          <h3>Diesel & Gas Generator Set</h3>
          <p>Diesel &amp; marine generator sets from 20 KVA to 2000 KVA. Export &amp; import of all types.</p>
        </div>
        <div class="offer-card">
          <Icon name="tools" size={36} class="offer-icon" />
          <h3>Spare Parts</h3>
          <p>Complete range of reconditioned spare parts including pistons, cylinder liners, bearings, and valves.</p>
        </div>
        <div class="offer-card">
          <Icon name="ship" size={36} class="offer-icon" />
          <h3>Hydraulic Deck Crane Equipment</h3>
          <p>Hydraulic crane systems, deck cranes, winches, and complete hydraulic power units.</p>
        </div>
        <div class="offer-card">
          <Icon name="anchor" size={36} class="offer-icon" />
          <h3>Anchor and Chain</h3>
          <p>Quality anchors and chains for various ship sizes sourced directly from recycling yards.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quality Policy -->
  <section class="section quality-policy" style="background:#1a1a2e;">
    <div class="container">
      <h2 class="section-title" style="color:#fff;">QUALITY POLICY</h2>
      <p class="qp-text">At Tahin Spare Suppliers, quality is our top priority. Every piece of equipment goes through a rigorous process of inspection, reconditioning, and testing before being offered to our customers. We are committed to providing marine equipment that meets international standards of quality, safety, and reliability. Our goal is 100% customer satisfaction — every time.</p>
      <div class="qp-steps">
        <div class="qp-step">
          <div class="qp-num">1</div>
          <h4>Source & Inspect</h4>
          <p>Equipment sourced from ship-breaking yards is thoroughly inspected for condition and usability.</p>
        </div>
        <div class="qp-step">
          <div class="qp-num">2</div>
          <h4>Recondition & Repair</h4>
          <p>Our skilled team reconditions, repairs, and overhauls each item in our workshop.</p>
        </div>
        <div class="qp-step">
          <div class="qp-num">3</div>
          <h4>Test & Certify</h4>
          <p>Every product undergoes rigorous testing to ensure full functionality before delivery.</p>
        </div>
        <div class="qp-step">
          <div class="qp-num">4</div>
          <h4>Pack & Ship</h4>
          <p>Products are properly packed and shipped worldwide with reliable logistics partners.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Mission -->
  <section class="section mission-section">
    <div class="container">
      <h2 class="section-title">OUR MISSION</h2>
      <p class="mission-text reveal">To be the most reliable and transparent bridge between the Bangladesh ship-breaking industry and global ship owners, providing sustainable and cost-effective machinery solutions.</p>
      <p class="mission-cta reveal">We are always looking to build long-term professional relationships with Technical Superintendents, Procurement Managers, Ship Managers, and Traders worldwide.</p>
    </div>
  </section>
</MainLayout>

<style>
  .page-hero {
    position: relative;
    height: 250px;
    background: url('/images/hero-bg.webp') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .page-hero-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); }
  .page-hero-content { position: relative; z-index: 1; color: #fff; }
  .page-hero-content h1 { font-size: 36px; font-weight: 700; margin-bottom: 8px; }
  .page-hero-content p { font-size: 14px; color: #ddd; }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    align-items: center;
  }
  .about-lead {
    font-size: 18px;
    font-weight: 600;
    color: #222;
    margin-bottom: 20px;
  }
  .about-text p {
    font-size: 14px;
    color: #555;
    line-height: 1.8;
    margin-bottom: 15px;
  }
  .about-image img {
    border-radius: 12px;
    box-shadow: 0 15px 40px rgba(0,0,0,0.1);
    width: 100%;
    height: auto;
    display: block;
  }

  /* Proprietor Section */
  .proprietor-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 60px;
    align-items: center;
  }
  .proprietor-info {
    text-align: center;
  }
  .proprietor-image img {
    width: 100%;
    max-width: 320px;
    display: block;
    margin: 0 auto;
    border-radius: 15px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    border: 8px solid #fff;
  }
  .proprietor-name {
    font-size: 24px;
    font-weight: 700;
    color: #c0392b;
    margin-bottom: 5px;
  }
  .proprietor-role {
    font-size: 16px;
    color: #666;
    font-weight: 500;
    margin-bottom: 25px;
    letter-spacing: 1px;
  }
  .proprietor-bio p {
    font-size: 15px;
    line-height: 1.8;
    color: #444;
    margin-bottom: 15px;
    text-align: center;
  }
  .proprietor-bio blockquote {
    font-size: 16px;
    font-style: italic;
    color: #222;
    border-left: none;
    padding-left: 0;
    margin: 20px auto;
    text-align: center;
    max-width: 500px;
  }

  /* Strength */
  .strength-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
  }
  .strength-card {
    text-align: center;
    padding: 35px 20px;
    background: #fff;
    border-radius: 10px;
    box-shadow: 0 2px 15px rgba(0,0,0,0.08);
    transition: transform 0.3s;
  }
  .strength-card:hover { transform: translateY(-5px); }
  .strength-card :global(.strength-icon) {
    color: #c0392b;
    margin-bottom: 15px;
  }
  .strength-card h3 {
    font-size: 17px;
    font-weight: 700;
    margin-bottom: 10px;
    color: #222;
  }
  .strength-card p {
    font-size: 13px;
    color: #666;
    line-height: 1.6;
  }

  /* What We Offer */
  .offer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
  }
  .offer-card {
    text-align: center;
    padding: 30px 20px;
    background: #f9f9f9;
    border-radius: 10px;
    box-shadow: 0 2px 15px rgba(0,0,0,0.06);
    transition: transform 0.3s;
  }
  .offer-card:hover { transform: translateY(-5px); }
  .offer-card :global(.offer-icon) {
    color: #c0392b;
    margin-bottom: 15px;
  }
  .offer-card h3 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 10px;
    color: #222;
  }
  .offer-card p {
    font-size: 13px;
    color: #666;
    line-height: 1.6;
  }

  /* Quality Policy */
  .qp-text {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 40px;
    font-size: 15px;
    color: #bbb;
    line-height: 1.8;
  }
  .qp-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
  }
  .qp-step {
    text-align: center;
    padding: 30px 20px;
    background: rgba(255,255,255,0.05);
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .qp-num {
    width: 50px;
    height: 50px;
    background: #c0392b;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    font-weight: 700;
    margin: 0 auto 15px;
  }
  .qp-step h4 {
    font-size: 16px;
    color: #fff;
    margin-bottom: 10px;
  }
  .qp-step p {
    font-size: 13px;
    color: #999;
    line-height: 1.6;
  }

  /* Mission */
  .mission-text {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 20px;
    font-size: 18px;
    color: #333;
    font-weight: 500;
    line-height: 1.8;
    font-style: italic;
  }
  .mission-cta {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
    font-size: 14px;
    color: #666;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; }
    .offer-grid { grid-template-columns: repeat(2, 1fr); }
    .strength-grid { grid-template-columns: repeat(2, 1fr); }
    .qp-steps { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .offer-grid { grid-template-columns: 1fr; }
    .strength-grid { grid-template-columns: 1fr; }
    .qp-steps { grid-template-columns: 1fr; }
  }
</style>
