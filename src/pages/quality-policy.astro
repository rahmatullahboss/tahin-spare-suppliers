---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Quality Policy - Tahin Spare Suppliers" activeNav="about">
  <section class="page-hero">
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <h1 class="reveal">Quality Policy</h1>
      <p class="reveal">Home / About Us / Quality Policy</p>
    </div>
  </section>

  <section class="section quality-policy">
    <div class="container">
      <h2 class="section-title">OUR QUALITY COMMITMENT</h2>
      <p class="qp-text reveal">At Tahin Spare Suppliers, quality is our top priority. Every piece of equipment goes through a rigorous process of inspection, reconditioning, and testing before being offered to our customers. We are committed to providing marine equipment that meets international standards of quality, safety, and reliability. Our goal is 100% customer satisfaction — every time.</p>
      
      <div class="qp-steps reveal-stagger">
        <div class="qp-step">
          <div class="qp-num">1</div>
          <h4>Source & Inspect</h4>
          <p>Equipment sourced from ship-breaking yards is thoroughly inspected for condition and usability by our senior engineers.</p>
        </div>
        <div class="qp-step">
          <div class="qp-num">2</div>
          <h4>Recondition & Repair</h4>
          <p>Our skilled team reconditions, repairs, and overhauls each item in our workshop. Worn out components are replaced with genuine marine replacements.</p>
        </div>
        <div class="qp-step">
          <div class="qp-num">3</div>
          <h4>Test & Certify</h4>
          <p>Every product undergoes rigorous load testing and calibration to ensure full functionality before delivery. Technical reports and video proofs are documented.</p>
        </div>
        <div class="qp-step">
          <div class="qp-num">4</div>
          <h4>Pack & Ship</h4>
          <p>Products are properly preserved with anti-rust packaging, crated securely, and shipped worldwide with reliable logistics partners.</p>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-hero {
    position: relative;
    height: 350px;
    background: url('/images/hero-bg.webp') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .page-hero-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); }
  .page-hero-content { position: relative; z-index: 1; color: #fff; }
  .page-hero-content h1 { font-size: 36px; font-weight: 700; margin-bottom: 8px; }
  .page-hero-content p { font-size: 14px; color: #ddd; }

  /* Quality Policy */
  .quality-policy {
    background: #fff;
  }
  .qp-text {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 40px;
    font-size: 16px;
    color: #444;
    line-height: 1.8;
  }
  .qp-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
    margin-top: 40px;
  }
  .qp-step {
    text-align: center;
    padding: 40px 20px;
    background: #f9f9f9;
    border-radius: 10px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    transition: transform 0.3s;
    border-bottom: 3px solid transparent;
  }
  .qp-step:hover {
    transform: translateY(-5px);
    border-bottom-color: #c0392b;
  }
  .qp-num {
    width: 60px;
    height: 60px;
    background: #c0392b;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    font-weight: 700;
    margin: 0 auto 20px;
    box-shadow: 0 5px 15px rgba(192, 57, 43, 0.3);
  }
  .qp-step h4 {
    font-size: 18px;
    color: #222;
    margin-bottom: 12px;
  }
  .qp-step p {
    font-size: 14px;
    color: #666;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .qp-steps { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .qp-steps { grid-template-columns: 1fr; }
  }
</style>
