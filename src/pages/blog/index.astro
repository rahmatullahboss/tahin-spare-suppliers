---
import MainLayout from "../../layouts/MainLayout.astro";
import { getRuntimeEnv } from "../../lib/server/env";
import { listContent } from "../../lib/server/repository";

const env = getRuntimeEnv(Astro.locals);
const posts = await listContent(env, "blog");
---
<MainLayout title="Blog - Tahin Spare Suppliers">
  <section class="page-hero">
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <h1>Blog</h1>
      <p>Marine supply updates, export notes and product highlights.</p>
    </div>
  </section>

  <section class="section">
    <div class="container blog-grid">
      {posts.length === 0 ? (
        <p>No posts yet.</p>
      ) : posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="blog-card">
          {post.imageUrl && <img src={post.imageUrl} alt={post.title} />}
          <div class="blog-card-body">
            <h2>{post.title}</h2>
            <p>{post.excerpt}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</MainLayout>

<style>
  .page-hero { position: relative; height: 280px; background: url('/images/services-hero.jpg') center/cover no-repeat; display: flex; align-items: center; justify-content: center; text-align: center; }
  .page-hero-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); }
  .page-hero-content { position: relative; z-index: 1; color: #fff; }
  .blog-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px; }
  .blog-card { text-decoration: none; color: inherit; background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
  .blog-card img { width: 100%; height: 220px; object-fit: cover; display: block; }
  .blog-card-body { padding: 20px; }
  .blog-card-body h2 { font-size: 22px; margin: 0 0 10px; }
  .blog-card-body p { margin: 0; color: #666; line-height: 1.7; }
  @media (max-width: 900px) { .blog-grid { grid-template-columns: 1fr; } }
</style>
