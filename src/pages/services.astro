---
import MainLayout from '../layouts/MainLayout.astro';
import Icon from '../components/Icon.astro';
---
<MainLayout title="Our Services - Tahin Spare Suppliers" activeNav="services">
  <section class="page-hero">
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <h1>Our Services</h1>
      <p>Home / Services</p>
    </div>
  </section>

  <!-- Services Intro -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">WHAT WE DO</h2>
      <p class="services-intro reveal">Tahin Spare Suppliers specializes in the supply and export of reconditioned marine engine spare parts and equipment. Located near the Chattogram Ship-Breaking Yards, we have direct access to a vast inventory of quality marine engine parts at competitive prices — ready for immediate dispatch worldwide.</p>
    </div>
  </section>

  <!-- Service 1: Marine Engine Parts Supply -->
  <section class="section" style="background:#f9f9f9;">
    <div class="container">
      <div class="service-detail">
        <div class="service-detail-text reveal-left">
          <div class="service-badge"><Icon name="layer-group" size={24} /></div>
          <h2>Marine Engine Parts Supply</h2>
          <p>Our core business is the supply and export of all kinds of reconditioned marine engine spare parts. We source directly from the Chattogram Ship-Breaking Yards, ensuring quality parts at the most competitive prices.</p>
          <ul>
            <li><Icon name="check" size={14} class="svc-check" /> Pistons, liners & cylinder heads</li>
            <li><Icon name="check" size={14} class="svc-check" /> Bearings, crankshafts & connecting rods</li>
            <li><Icon name="check" size={14} class="svc-check" /> Fuel pumps, injectors & fuel systems</li>
            <li><Icon name="check" size={14} class="svc-check" /> Turbochargers — ABB, MHI, IHI, Napier</li>
            <li><Icon name="check" size={14} class="svc-check" /> Gaskets, valves & seals for all engine types</li>
          </ul>
          <a href="/enquiry" class="btn btn-primary">Request Parts Quote</a>
        </div>
        <div class="service-detail-img">
          <img src="/images/spare-parts.webp" alt="Marine Engine Spare Parts" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Service 2: Engine Overhaul & Reconditioning -->
  <section class="section">
    <div class="container">
      <div class="service-detail reverse">
        <div class="service-detail-text reveal-right">
          <div class="service-badge"><Icon name="tools" size={24} /></div>
          <h2>Engine Overhaul & Reconditioning</h2>
          <p>Our workshop team carries out complete engine overhaul and reconditioning for all major marine engine brands. Every part is inspected, tested and certified before delivery.</p>
          <ul>
            <li><Icon name="check" size={14} class="svc-check" /> Full engine disassembly, cleaning &amp; inspection</li>
            <li><Icon name="check" size={14} class="svc-check" /> Component reconditioning &amp; replacement</li>
            <li><Icon name="check" size={14} class="svc-check" /> Precision reassembly &amp; calibration</li>
            <li><Icon name="check" size={14} class="svc-check" /> Load testing &amp; performance verification</li>
            <li><Icon name="check" size={14} class="svc-check" /> Quality certification before dispatch</li>
            <li><Icon name="check" size={14} class="svc-check" /> Brands: Yanmar · Daihatsu · Caterpillar · Cummins · Mitsubishi · Bergen · Wartsila</li>
          </ul>
          <a href="/enquiry" class="btn btn-primary">Get a Quote</a>
        </div>
        <div class="service-detail-img">
          <img src="/images/marine-engine.webp" alt="Engine Overhaul & Reconditioning" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Service 3: Worldwide Export -->
  <section class="section" style="background:#f9f9f9;">
    <div class="container">
      <div class="service-detail">
        <div class="service-detail-text reveal-left">
          <div class="service-badge"><Icon name="globe" size={24} /></div>
          <h2>Worldwide Parts Export</h2>
          <p>We export marine engines, generator sets, hydraulic equipment and engine spare parts worldwide. Our logistics team ensures all items are properly packed and shipped through reliable international freight carriers for timely delivery.</p>
          <ul>
            <li><Icon name="check" size={14} class="svc-check" /> Export to Asia, Middle East, Africa & Europe</li>
            <li><Icon name="check" size={14} class="svc-check" /> Proper packing & documentation support</li>
            <li><Icon name="check" size={14} class="svc-check" /> All commercial & shipping documents provided</li>
            <li><Icon name="check" size={14} class="svc-check" /> Competitive freight rates via sea & air</li>
            <li><Icon name="check" size={14} class="svc-check" /> Ready stock for immediate dispatch</li>
          </ul>
          <a href="/enquiry" class="btn btn-primary">Send Export Enquiry</a>
        </div>
        <div class="service-detail-img">
          <img src="/images/shipping-dock.jpg" alt="Worldwide Marine Parts Export" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-overlay"></div>
    <div class="container cta-content">
      <h2>Need Marine Engine Parts or Equipment?</h2>
      <p>Contact us today for a free quote. Ready stock available — worldwide delivery.</p>
      <div class="cta-btns">
        <a href="/enquiry" class="btn btn-primary">Send Enquiry</a>
        <a href="https://wa.me/8801787429268" class="btn btn-outline" target="_blank" rel="noopener">WhatsApp Us</a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-hero {
    position: relative;
    height: 350px;
    background: url('/images/services-hero.jpg') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .page-hero-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); }
  .page-hero-content { position: relative; z-index: 1; color: #fff; }
  .page-hero-content h1 { font-size: 36px; font-weight: 700; margin-bottom: 8px; }
  .page-hero-content p { font-size: 14px; color: #ddd; }

  .services-intro {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    font-size: 15px;
    color: #555;
    line-height: 1.8;
  }

  .service-detail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    align-items: center;
  }
  .service-detail.reverse {
    direction: rtl;
  }
  .service-detail.reverse > * {
    direction: ltr;
  }
  .service-badge {
    width: 56px;
    height: 56px;
    background: #c0392b;
    color: #fff;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }
  .service-detail-text h2 {
    font-size: 26px;
    font-weight: 700;
    color: #222;
    margin-bottom: 15px;
  }
  .service-detail-text p {
    font-size: 14px;
    color: #555;
    line-height: 1.8;
    margin-bottom: 20px;
  }
  .service-detail-text ul {
    list-style: none;
    padding: 0;
    margin: 0 0 25px;
  }
  .service-detail-text li {
    font-size: 14px;
    color: #555;
    padding: 5px 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .service-detail-text :global(.svc-check) {
    color: #2ecc71;
    flex-shrink: 0;
  }
  .service-detail-img img {
    width: 100%;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
  }

  /* CTA */
  .cta-section {
    position: relative;
    background: url('/images/hero-bg.webp') center/cover no-repeat;
    padding: 80px 0;
    text-align: center;
  }
  .cta-overlay {
    position: absolute;
    inset: 0;
    background: rgba(80, 20, 120, 0.8);
  }
  .cta-content {
    position: relative;
    z-index: 1;
  }
  .cta-content h2 {
    color: #fff;
    font-size: 30px;
    font-weight: 700;
    margin-bottom: 12px;
    font-family: var(--font-playfair), 'Playfair Display', serif;
  }
  .cta-content p {
    color: #ddd;
    font-size: 16px;
    margin-bottom: 30px;
  }
  .cta-btns {
    display: flex;
    gap: 15px;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .service-detail { grid-template-columns: 1fr; }
    .service-detail.reverse { direction: ltr; }
  }
</style>
