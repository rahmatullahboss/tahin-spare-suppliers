---
import MainLayout from '../layouts/MainLayout.astro';
import ProductGrid from '../components/ProductGrid.astro';
import { getRuntimeEnv } from '../lib/server/env';
import { listContent } from '../lib/server/repository';

const env = getRuntimeEnv(Astro.locals);
const liveParts = await listContent(env, 'parts');
---
<MainLayout title="Marine Spare Parts - Tahin Spare Suppliers" activeNav="products">
  <section class="page-hero">
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
      <h1 class="reveal">Marine Spare Parts</h1>
    </div>
  </section>

  <section class="section">
    <div class="container product-detail-container">
      <div class="content-side reveal-left">
        <h2>Comprehensive Marine Component Supply</h2>
        <p>In addition to complete engines and generators, we maintain an extensive inventory of essential marine spare parts to support your vessel's maintenance and overhaul needs. From pistons to valves, we stock genuine parts dismantled from retired vessels.</p>
        
        <div class="features-list">
          <ul>
            <li>Pistons, cylinder liners, bearings, and connecting rods</li>
            <li>Fuel injection pumps, injectors, and nozzles</li>
            <li>Valves, springs, rotators, and seat rings</li>
            <li>Huge inventory ensuring quick order turnarounds</li>
          </ul>
        </div>
        
        <a href="/enquiry" class="btn-primary" style="margin-top: 20px;">Request Inventory List</a>
      </div>
      <div class="image-side reveal-right img-zoom">
        <img src="/images/spare-parts-new.jpg" alt="Marine Spare Parts" loading="lazy" />
      </div>
    </div>
  </section>

  {liveParts.length > 0 && (
    <section class="section live-parts-section" style="background: #f9f9f9;">
      <div class="container">
        <h2 class="live-title">Live Parts Inventory</h2>
        <ProductGrid products={liveParts} basePath="/parts" />
      </div>
    </section>
  )}
</MainLayout>

<style>
  .page-hero {
    position: relative;
    height: 350px;
    background: url('/images/hero-bg.webp') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .page-hero-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); }
  .page-hero-content { position: relative; z-index: 1; color: #fff; }
  .page-hero-content h1 { font-size: 36px; font-weight: 700; margin-bottom: 8px; }
  .page-hero-content p { font-size: 14px; color: #ddd; }

  .product-detail-container {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 50px;
    align-items: center;
  }
  .content-side h2 {
    font-size: 28px;
    color: #222;
    margin-bottom: 20px;
  }
  .content-side p {
    font-size: 15px;
    color: #555;
    line-height: 1.8;
    margin-bottom: 15px;
  }
  .features-list ul {
    list-style: none;
    padding: 0;
    margin: 25px 0;
  }
  .features-list li {
    position: relative;
    padding-left: 25px;
    margin-bottom: 12px;
    font-size: 15px;
    color: #444;
  }
  .features-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0;
    color: #c0392b;
    font-weight: bold;
  }
  .image-side img {
    width: 100%;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }
  .btn-primary {
    display: inline-block;
    background: #c0392b;
    color: #fff;
    padding: 12px 25px;
    text-decoration: none;
    font-weight: 600;
    border-radius: 4px;
    transition: background 0.3s;
  }
  .btn-primary:hover {
    background: #a93226;
  }
  .live-parts-section {
    padding-top: 0;
  }
  .live-title {
    text-align: center;
    font-size: 30px;
    margin-bottom: 24px;
  }
  .parts-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }
  .part-card {
    text-decoration: none;
    color: inherit;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.06);
  }
  .part-card img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
  }
  .part-card-body {
    padding: 18px;
  }
  .part-card-body h3 {
    margin: 0 0 10px;
  }
  .part-card-body p {
    margin: 0;
  }

  @media (max-width: 768px) {
    .product-detail-container { grid-template-columns: 1fr; }
    .image-side { order: -1; }
    .parts-grid { grid-template-columns: 1fr; }
  }
</style>
