---
import { Font } from 'astro:assets';
import Header from '../components/Header.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  activeNav?: string;
}

const { title = 'Tahin Spare Suppliers - Supply & Export All Kinds Of Marine Spare Parts', activeNav = 'home' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Tahin Spare Suppliers - Supply & Export All Kinds Of Marine Spare Parts from Bangladesh. Leading marine machinery and spares parts supplier." />
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-playfair" preload />
    <Font cssVariable="--font-dancing" preload />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <Navbar activeNav={activeNav} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
