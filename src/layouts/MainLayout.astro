---
import Header from '../components/Header.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  activeNav?: string;
}

const { title = 'Tahin Spare Suppliers - Supply & Export All Kinds Of Marine Spare Parts', activeNav = 'home' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Tahin Spare Suppliers - Supply & Export All Kinds Of Marine Spare Parts from Bangladesh. Leading marine machinery and spares parts supplier." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <Navbar activeNav={activeNav} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
