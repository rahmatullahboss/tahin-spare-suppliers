---
import "../styles/global.css";
import AdminSidebar from "../components/admin/AdminSidebar.astro";

interface Props {
  title: string;
  active: "dashboard" | "products" | "parts" | "blog";
}

const { title, active } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <div class="admin-shell">
      <AdminSidebar active={active} />
      <main class="admin-main">
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  .admin-shell {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 260px 1fr;
    background: #f5f5f5;
  }
  :global(.admin-sidebar) {
    background: #161616;
    color: #fff;
    padding: 32px 22px;
  }
  :global(.admin-sidebar h2) {
    margin-bottom: 24px;
    font-size: 24px;
  }
  :global(.admin-sidebar nav) {
    display: grid;
    gap: 10px;
  }
  :global(.admin-sidebar a) {
    text-decoration: none;
    color: rgba(255,255,255,0.82);
    padding: 12px 14px;
    border-radius: 10px;
    font-weight: 600;
  }
  :global(.admin-sidebar a.active),
  :global(.admin-sidebar a:hover) {
    background: #c78f40;
    color: #111;
  }
  .admin-main {
    padding: 32px;
  }
  @media (max-width: 900px) {
    .admin-shell {
      grid-template-columns: 1fr;
    }
    :global(.admin-sidebar) {
      padding: 20px;
    }
    .admin-main {
      padding: 20px;
    }
  }
</style>
