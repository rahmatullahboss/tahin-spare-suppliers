---
interface Props {
  active: "dashboard" | "products" | "parts" | "blog";
}

const { active } = Astro.props;
---
<aside class="admin-sidebar">
  <h2>Admin Panel</h2>
  <nav>
    <a href="/admin" class:list={[{ active: active === "dashboard" }]}>Dashboard</a>
    <a href="/admin/products" class:list={[{ active: active === "products" }]}>Products</a>
    <a href="/admin/parts" class:list={[{ active: active === "parts" }]}>Parts</a>
    <a href="/admin/blog" class:list={[{ active: active === "blog" }]}>Blog</a>
  </nav>
</aside>
