---
import Icon from './Icon.astro';
---
<header class="top-header">
  <div class="header-container">
    <div class="logo">
      <div class="logo-icon">
        <!-- Tahin Spare Suppliers — real logo recreation -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 60" width="56" height="56" aria-label="Tahin Spare Suppliers Logo">
          <!-- White circle base -->
          <circle cx="30" cy="30" r="28" fill="#fff" stroke="#222" stroke-width="2.5"/>
          <!-- Red upper semicircle (above T crossbar at y=32) -->
          <clipPath id="top-clip">
            <rect x="0" y="2" width="60" height="30"/>
          </clipPath>
          <circle cx="30" cy="30" r="27.5" fill="#cc0000" clip-path="url(#top-clip)"/>
          <!-- White T crossbar (horizontal bar spanning the circle middle) -->
          <rect x="10" y="26" width="40" height="8" fill="#fff" rx="1"/>
          <!-- Red T stem (vertical bar below crossbar) -->
          <rect x="23" y="34" width="14" height="20" fill="#cc0000" rx="1"/>
          <!-- Clip the stem to the circle boundary -->
          <circle cx="30" cy="30" r="27.5" fill="none" stroke="#222" stroke-width="2.5"/>
        </svg>
      </div>
      <div class="logo-text">
        <h1 class="company-name">Tahin Spare Suppliers</h1>
        <p class="company-tagline">Supply & Export All Kinds Of Marine Engine & Spare Parts</p>
      </div>
    </div>
    <div class="social-icons">
      <a href="#" class="social-icon facebook" aria-label="Facebook"><Icon name="facebook-f" size={14} /></a>
      <a href="#" class="social-icon twitter" aria-label="Twitter"><Icon name="twitter" size={14} /></a>
      <a href="#" class="social-icon youtube" aria-label="YouTube"><Icon name="youtube" size={14} /></a>
      <a href="https://www.linkedin.com/in/tahin-spare-suppliers-a65b133a8/" class="social-icon linkedin" aria-label="LinkedIn" target="_blank" rel="noopener"><Icon name="linkedin-in" size={14} /></a>
    </div>
  </div>
</header>

<style>
  .top-header {
    background: #fff;
    padding: 12px 0;
    border-bottom: 1px solid #eee;
  }
  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 20px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .logo-icon svg {
    display: block;
    filter: drop-shadow(0 1px 3px rgba(0,0,0,0.15));
  }
  .company-name {
    font-family: var(--font-dancing), 'Dancing Script', cursive;
    font-size: 28px;
    color: #d4a00a;
    margin: 0;
    line-height: 1.1;
    font-weight: 700;
  }
  .company-tagline {
    font-size: 11px;
    color: #333;
    margin: 0;
    font-family: var(--font-inter), 'Inter', sans-serif;
  }
  .social-icons {
    display: flex;
    gap: 6px;
  }
  .social-icon {
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    color: #fff;
    font-size: 14px;
    text-decoration: none;
    transition: opacity 0.3s;
  }
  .social-icon:hover {
    opacity: 0.8;
  }
  .social-icon.facebook { background: #3b5998; }
  .social-icon.twitter { background: #1da1f2; }
  .social-icon.youtube { background: #ff0000; }
  .social-icon.linkedin { background: #0077b5; }

  @media (max-width: 600px) {
    .company-name { font-size: 20px; }
    .header-container { flex-direction: column; gap: 10px; }
  }
</style>
