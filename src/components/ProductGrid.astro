---
interface Props {
  products: any[];
  basePath?: string;
}
const { products, basePath = '/products' } = Astro.props;

// Group products by brand
const groupedProducts = products.reduce((acc, product) => {
  const brandName = product.brand || 'Other / Generic';
  if (!acc[brandName]) acc[brandName] = [];
  acc[brandName].push(product);
  return acc;
}, {} as Record<string, any[]>);

const sortedBrands = Object.keys(groupedProducts).sort((a, b) => {
  if (a === 'Other / Generic') return 1;
  if (b === 'Other / Generic') return -1;
  return a.localeCompare(b);
});
---

<div class="product-group-container">
  {sortedBrands.map(brand => (
    <div class="brand-section">
      <div class="brand-header">
        <h3 class="brand-title">{brand}</h3>
        <span class="brand-count">{groupedProducts[brand].length} Models Available</span>
      </div>
      <div class="products-grid">
        {groupedProducts[brand].map((product: any) => (
          <a href={`${basePath}/${product.slug}`} class="product-card" data-brand={product.brand || ''}>
            {product.imageUrl && (
              <div class="product-img">
                <img src={product.imageUrl} alt={product.title} loading="lazy" />
              </div>
            )}
            <div class="product-content">
              <h4>{product.title}</h4>
              {product.model_number && <p class="product-model">Model: {product.model_number}</p>}
              {product.excerpt && <p class="live-excerpt">{product.excerpt}</p>}
              <span class="view-details">VIEW DETAILS</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  ))}
</div>

<style>
  .product-group-container {
    display: flex;
    flex-direction: column;
    gap: 50px;
    margin-top: 20px;
  }
  .brand-section {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #eaeaea;
    padding: 30px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
  }
  .brand-header {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 24px;
    padding-bottom: 15px;
    border-bottom: 2px solid #f5f5f5;
  }
  .brand-title {
    font-size: 24px;
    font-weight: 800;
    color: #111;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .brand-count {
    background: #e67e22;
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 20px;
    text-transform: uppercase;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 30px;
  }
  .product-card {
    position: relative;
    border-radius: 0;
    background: #fff;
    border: 1px solid #eaeaea;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.04);
    transition: transform 0.35s ease, box-shadow 0.35s ease;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }
  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 35px rgba(0,0,0,0.1);
  }
  .product-img {
    width: 100%;
    height: 240px;
    position: relative;
    overflow: hidden;
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 92%);
  }
  .product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .product-card:hover .product-img img {
    transform: scale(1.06);
  }
  .product-content {
    padding: 24px 24px 30px;
    background: #fff;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .product-content h4 {
    font-size: 20px;
    color: #111;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 8px;
    font-family: var(--font-inter), 'Inter', sans-serif;
  }
  .product-brand {
    font-size: 11px;
    font-weight: 700;
    color: #e67e22;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
    display: inline-block;
  }
  .product-model {
    font-size: 13px;
    color: #444;
    font-weight: 500;
    margin: 0 0 10px;
    background: #f1f1f1;
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    width: fit-content;
  }
  .live-excerpt {
    margin: 0 0 16px;
    color: #666;
    line-height: 1.7;
    font-size: 14px;
  }
  .view-details {
    font-size: 13px;
    color: #e67e22;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: color 0.3s;
    margin-top: auto;
  }
  .product-card:hover .view-details {
    color: #c0392b;
  }

  @media (max-width: 768px) {
    .products-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .products-grid { grid-template-columns: 1fr; }
  }
</style>
